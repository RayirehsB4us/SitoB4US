<!DOCTYPE html>
<html class="scroll-smooth" lang="it">

<head>
  <%- include('partials/head') %>
</head>

<body class="bg-background-light text-slate-800 font-sans transition-colors duration-300">
  <%- include('partials/navbar') %>

    <section class="relative py-20 overflow-hidden">
      <div class="absolute inset-0 text-slate-100 dark:text-slate-900 bg-grid-pattern opacity-50 -z-10"></div>
      <div class="container mx-auto px-6">
        <div class="max-w-3xl">
          <h1 class="font-display text-5xl md:text-6xl font-bold mb-6 text-slate-900 dark:text-white leading-tight">
            Struttura e <span class="text-primary">Organizzazione</span>
          </h1>
          <p class="text-xl text-slate-600 dark:text-slate-400 leading-relaxed">
            Un modello flessibile e dinamico progettato per semplificare l'IT. La nostra struttura organizzativa è il
            motore che ci permette di offrire consulenza d'eccellenza e soluzioni innovative.
          </p>
        </div>
      </div>
    </section>
    <section class="py-24">
      <div class="container mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="font-display text-3xl font-bold mb-4">La Nostra Squadra</h2>
          <p class="text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">Semplifichiamo processi complessi attraverso
            una gerarchia piatta e collaborativa.</p>
        </div>
        <div class="max-w-5xl mx-auto flex flex-col items-center gap-12">
          <div class="relative org-line">
            <div class="bg-primary text-white p-6 rounded-xl shadow-lg w-72 text-center">
              <span class="material-symbols-outlined mb-2 text-4xl">corporate_fare</span>
              <h3 class="font-bold text-lg">Direzione Generale</h3>
              <p class="text-sm opacity-90">Strategia e Visione</p>
            </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 w-full">
            <div
              class="bg-surface-light dark:bg-surface-dark p-8 rounded-2xl border border-slate-200 dark:border-slate-800 hover:border-primary transition-all group">
              <div
                class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-primary transition-colors">
                <span class="material-symbols-outlined text-primary group-hover:text-white">psychology</span>
              </div>
              <h4 class="font-bold text-xl mb-3">Consulenza IT</h4>
              <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed mb-4">
                Analisi infrastrutturale, cloud transformation e roadmap tecnologiche personalizzate.
              </p>
              <ul class="space-y-2 text-sm text-slate-500 dark:text-slate-500">
                <li class="flex items-center gap-2"><span class="material-symbols-outlined text-xs">check</span> IT
                  Audit</li>
                <li class="flex items-center gap-2"><span class="material-symbols-outlined text-xs">check</span> Cloud
                  Strategy
                </li>
                <li class="flex items-center gap-2"><span class="material-symbols-outlined text-xs">check</span> Digital
                  Transformation</li>
              </ul>
            </div>
            <div
              class="bg-surface-light dark:bg-surface-dark p-8 rounded-2xl border border-slate-200 dark:border-slate-800 hover:border-primary transition-all group">
              <div
                class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-primary transition-colors">
                <span
                  class="material-symbols-outlined text-primary group-hover:text-white">integration_instructions</span>
              </div>
              <h4 class="font-bold text-xl mb-3">Servizi &amp; Soluzioni</h4>
              <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed mb-4">
                Implementazione di architetture software e gestione di infrastrutture mission-critical.
              </p>
              <ul class="space-y-2 text-sm text-slate-500 dark:text-slate-500">
                <li class="flex items-center gap-2"><span class="material-symbols-outlined text-xs">check</span> Managed
                  Services
                </li>
                <li class="flex items-center gap-2"><span class="material-symbols-outlined text-xs">check</span>
                  Software
                  Development</li>
                <li class="flex items-center gap-2"><span class="material-symbols-outlined text-xs">check</span>
                  Security
                  Operations</li>
              </ul>
            </div>
            <div
              class="bg-surface-light dark:bg-surface-dark p-8 rounded-2xl border border-slate-200 dark:border-slate-800 hover:border-primary transition-all group">
              <div
                class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-primary transition-colors">
                <span class="material-symbols-outlined text-primary group-hover:text-white">admin_panel_settings</span>
              </div>
              <h4 class="font-bold text-xl mb-3">Operations</h4>
              <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed mb-4">
                Amministrazione, Risorse Umane e Customer Success per garantire continuità.
              </p>
              <ul class="space-y-2 text-sm text-slate-500 dark:text-slate-500">
                <li class="flex items-center gap-2"><span class="material-symbols-outlined text-xs">check</span> HR
                  &amp;
                  Recruiting</li>
                <li class="flex items-center gap-2"><span class="material-symbols-outlined text-xs">check</span> Quality
                  Control
                </li>
                <li class="flex items-center gap-2"><span class="material-symbols-outlined text-xs">check</span>
                  Compliance</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>
    <section class="py-24 bg-primary text-white">
      <div class="container mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-12 text-center">
          <div>
            <div class="text-4xl font-display font-bold mb-2">10+</div>
            <div class="text-primary-100 opacity-80 uppercase tracking-widest text-xs font-bold">Anni di Esperienza
            </div>
          </div>
          <div>
            <div class="text-4xl font-display font-bold mb-2">200+</div>
            <div class="text-primary-100 opacity-80 uppercase tracking-widest text-xs font-bold">Progetti Completati
            </div>
          </div>
          <div>
            <div class="text-4xl font-display font-bold mb-2">20+</div>
            <div class="text-primary-100 opacity-80 uppercase tracking-widest text-xs font-bold">Esperti IT</div>
          </div>
          <div>
            <div class="text-4xl font-display font-bold mb-2">24/7</div>
            <div class="text-primary-100 opacity-80 uppercase tracking-widest text-xs font-bold">Supporto Dedicato</div>
          </div>
        </div>
      </div>
    </section>

    <%- include('partials/footer') %>
</body>

</html>