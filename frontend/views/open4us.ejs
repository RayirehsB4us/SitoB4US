<!DOCTYPE html>
<html class="scroll-smooth" lang="it">

<head>
    <%- include('partials/head') %>
        <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
        <style>
            @keyframes bounce-in {
                0% {
                    opacity: 0;
                    transform: scale(0.9);
                }

                100% {
                    opacity: 1;
                    transform: scale(1);
                }
            }

            .animate-bounce-in {
                animation: bounce-in 0.5s ease-out;
            }

            .hover-lift {
                transition: all 0.3s ease;
            }

            .hover-lift:hover {
                transform: translateY(-4px);
                box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.1);
            }
        </style>
</head>

<body class="bg-background-light text-secondary font-sans transition-colors duration-300">
    <%- include('partials/topNav') %>
    <%- include('partials/skeleton-page') %>

        <main id="page-content" class="pt-16 hidden opacity-0 transition-opacity duration-300">
            <!-- Hero Section -->
            <div class="relative overflow-hidden py-16 lg:py-24">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col lg:flex-row items-center gap-12">
                    <div class="lg:w-1/2 lg:pr-12">
                        <div
                            class="inline-flex items-center px-3 py-1 rounded-full bg-green-100 text-primary text-xs font-semibold tracking-wide uppercase mb-6">
                            <%- (o4u && o4u.UpperMainTitle) || '' %>
                        </div>
                        <h1 class="text-4xl lg:text-6xl font-extrabold tracking-tight text-gray-900 mb-6">
                            <%- (o4u && o4u.MainTitle) || '' %>
                        </h1>
                        <p class="text-lg text-gray-600 mb-8 leading-relaxed">
                            <% if (o4u && o4u.MainSubTitle) { %>
                                <%- o4u.MainSubTitle %>
                                    <% } else { %>
                                        Gestisci i tuoi spazi senza sforzo con Open4US. Da hub di coworking a palestre,
                                        automatizza l'ingresso con la nostra avanzata integrazione di serrature smart
                                        ISEO e potente dashboard cloud.
                                        <% } %>
                        </p>
                        <div class="flex flex-col sm:flex-row gap-4">
                            <button onclick="openDemoModal('Open4US')"
                                class="flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-lg text-white bg-primary hover:bg-green-600 md:text-lg shadow-lg shadow-green-500/40 transition-transform transform hover:-translate-y-1">
                                <%= (o4u && o4u.MainButton1) || '' %>
                                    <span class="material-icons ml-2">
                                        <%= (o4u && o4u.MainIcon) || '' %>
                                    </span>
                            </button>
                            <a href="#features"
                                class="flex items-center justify-center px-8 py-3 border border-gray-300 text-base font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 md:text-lg transition-colors">
                                <%= (o4u && o4u.MainButton2) || '' %>
                            </a>
                        </div>
                        <div class="mt-8 flex flex-wrap items-center gap-6 text-gray-400 text-sm font-medium">
                            <% if (o4u && o4u.AccesSmart && o4u.AccesSmart.length> 0) { %>
                                <% o4u.AccesSmart.forEach(function(chip) { %>
                                    <div class="flex items-center gap-1">
                                        <span class="material-icons text-primary text-base">
                                            <%= chip.Icon || '' %>
                                        </span>
                                        <%= chip.Text %>
                                    </div>
                                    <% }); %>
                                        <% } else { %>
                                            <div class="flex items-center gap-1">
                                                <span class="material-icons text-primary text-base">check_circle</span>
                                                Configurazione Istantanea
                                            </div>
                                            <div class="flex items-center gap-1">
                                                <span class="material-icons text-primary text-base">check_circle</span>
                                                Bluetooth Sicuro
                                            </div>
                                            <div class="flex items-center gap-1">
                                                <span class="material-icons text-primary text-base">check_circle</span>
                                                Monitoraggio 24/7
                                            </div>
                                            <% } %>
                        </div>
                    </div>

                    <div class="lg:w-1/2 relative">
                        <div
                            class="absolute top-0 right-0 -mr-20 -mt-20 w-72 h-72 bg-primary opacity-20 blur-3xl rounded-full">
                        </div>
                        <div
                            class="absolute bottom-0 left-0 -ml-20 -mb-20 w-72 h-72 bg-blue-400 opacity-20 blur-3xl rounded-full">
                        </div>
                        <div class="relative z-10 grid grid-cols-2 gap-4">
                            <div
                                class="col-span-2 sm:col-span-1 bg-white rounded-2xl shadow-xl p-6 flex flex-col items-center justify-center hover-lift border border-gray-100">
                                <div class="w-full h-48 relative mb-4">
                                    <img src="/images/smart-lock.png" alt="Cilindro Elettronico Smart ISEO Libra"
                                        class="w-full h-full object-contain drop-shadow-lg">
                                </div>
                                <h3 class="text-lg font-bold text-gray-900">
                                    <%- (o4u && o4u.ImageCard && o4u.ImageCard.Title) || '' %>
                                </h3>
                                <p class="text-sm text-gray-500 text-center mt-1">
                                    <%= (o4u && o4u.ImageCard && o4u.ImageCard.SubTitle)
                                        || '' %>
                                </p>
                            </div>
                            <div
                                class="col-span-2 sm:col-span-1 bg-gray-900 rounded-2xl shadow-xl p-4 flex flex-col items-center justify-center transform translate-y-8 sm:translate-y-12 border border-gray-700">
                                <div class="w-full bg-gray-800 rounded-xl overflow-hidden mb-2 relative">
                                    <div
                                        class="h-48 bg-gradient-to-br from-gray-800 to-gray-900 p-4 flex flex-col items-center justify-center">
                                        <div
                                            class="w-16 h-16 rounded-full border-4 border-primary flex items-center justify-center mb-3 shadow-[0_0_15px_rgba(46,170,110,0.5)]">
                                            <span class="material-icons text-primary text-3xl">
                                                <%= (o4u && o4u.SmartBlock && o4u.SmartBlock.Icon) || '' %>
                                            </span>
                                        </div>
                                        <span class="text-white font-medium text-sm">
                                            <%= (o4u && o4u.SmartBlock && o4u.SmartBlock.Title) || ''
                                                %>
                                        </span>
                                        <span class="text-gray-400 text-xs mt-1">
                                            <%= (o4u && o4u.SmartBlock && o4u.SmartBlock.Description)
                                                || '' %>
                                        </span>
                                    </div>
                                </div>
                                <div class="flex justify-between w-full px-2 mt-2">
                                    <div class="h-1 w-1/3 bg-gray-700 rounded-full"></div>
                                    <div class="h-1 w-1/3 bg-primary rounded-full"></div>
                                    <div class="h-1 w-1/3 bg-gray-700 rounded-full"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Dashboard Section -->
            <div id="features" class="bg-gray-50 py-24 border-t border-gray-200">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                    <div class="text-center mb-16">
                        <h2 class="text-primary font-semibold tracking-wide uppercase text-sm">
                            <%- (o4u && o4u.DashUpperTitle) || '' %>
                        </h2>
                        <p class="mt-2 text-3xl leading-8 font-extrabold tracking-tight text-gray-900 sm:text-4xl">
                            <%- (o4u && o4u.DashTitle) || '' %>
                        </p>
                        <p class="mt-4 max-w-2xl text-xl text-gray-500 mx-auto">
                            <% if (o4u && o4u.DashSubTitle) { %>
                                <%- o4u.DashSubTitle %>
                                    <% } else { %>
                                        Visualizza prenotazioni, gestisci diritti di accesso e monitora la tua struttura
                                        in tempo reale. Tutto ciò di cui hai bisogno in un'unica piattaforma
                                        centralizzata.
                                        <% } %>
                        </p>
                    </div>

                    <div class="relative bg-white rounded-2xl shadow-2xl border border-gray-200 overflow-hidden">
                        <div class="bg-gray-100 px-4 py-3 border-b border-gray-200 flex items-center gap-2">
                            <div class="flex gap-1.5">
                                <div class="w-3 h-3 rounded-full bg-red-400"></div>
                                <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
                                <div class="w-3 h-3 rounded-full bg-green-400"></div>
                            </div>
                            <div
                                class="bg-white px-3 py-1 rounded text-xs text-gray-500 flex-1 text-center font-mono mx-4 border border-gray-200">
                                <%= (o4u && o4u.DashLink) || '' %>
                            </div>
                        </div>

                        <div class="flex flex-col md:flex-row min-h-[600px]">
                            <!-- Sidebar -->
                            <div
                                class="w-full md:w-64 bg-primary text-white p-6 flex flex-col gap-6 hidden md:flex shrink-0">
                                <div class="flex items-center gap-3 mb-4">
                                    <div
                                        class="w-10 h-10 bg-white rounded-full flex items-center justify-center text-primary font-bold">
                                        <%= (o4u && o4u.DashIcon) || '' %>
                                    </div>
                                    <div>
                                        <h4 class="font-bold text-sm">
                                            <%= (o4u && o4u.DashName) || '' %>
                                        </h4>
                                        <span class="text-xs text-green-100">
                                            <%= (o4u && o4u.DashRole) || '' %>
                                        </span>
                                    </div>
                                </div>
                                <% var navItems=(o4u && o4u.DashboardOptions) ? o4u.DashboardOptions : []; var
                                    navMain=navItems.slice(0, navItems.length - 1); var
                                    navLogout=navItems[navItems.length - 1]; %>
                                    <% if (navMain.length> 0) { %>
                                        <nav class="space-y-2">
                                            <% navMain.forEach(function(opt, idx) { %>
                                                <% if (idx===1) { %>
                                                    <a class="flex items-center gap-3 text-white bg-white/20 p-2 rounded font-medium shadow-sm"
                                                        href="#">
                                                        <span class="material-icons text-sm">
                                                            <%= opt.Icon %>
                                                        </span>
                                                        <%= opt.Text %>
                                                    </a>
                                                    <% } else { %>
                                                        <a class="flex items-center gap-3 text-green-100 hover:text-white hover:bg-white/10 p-2 rounded transition"
                                                            href="#">
                                                            <span class="material-icons text-sm">
                                                                <%= opt.Icon %>
                                                            </span>
                                                            <%= opt.Text %>
                                                        </a>
                                                        <% } %>
                                                            <% }); %>
                                        </nav>
                                        <div class="mt-auto">
                                            <% if (navLogout) { %>
                                                <a class="flex items-center gap-3 text-green-100 hover:text-white p-2"
                                                    href="#">
                                                    <span class="material-icons text-sm">
                                                        <%= navLogout.Icon %>
                                                    </span>
                                                    <%= navLogout.Text %>
                                                </a>
                                                <% } else { %>
                                                    <a class="flex items-center gap-3 text-green-100 hover:text-white p-2"
                                                        href="#">
                                                        <span class="material-icons text-sm">logout</span> Logout
                                                    </a>
                                                    <% } %>
                                        </div>
                                        <% } else { %>
                                            <nav class="space-y-2">
                                                <a class="flex items-center gap-3 text-green-100 hover:text-white hover:bg-white/10 p-2 rounded transition"
                                                    href="#">
                                                    <span class="material-icons text-sm">home</span> Home
                                                </a>
                                                <a class="flex items-center gap-3 text-white bg-white/20 p-2 rounded font-medium shadow-sm"
                                                    href="#">
                                                    <span class="material-icons text-sm">calendar_today</span>
                                                    Prenotazioni
                                                </a>
                                                <a class="flex items-center gap-3 text-green-100 hover:text-white hover:bg-white/10 p-2 rounded transition"
                                                    href="#">
                                                    <span class="material-icons text-sm">people</span> Utenti
                                                </a>
                                                <a class="flex items-center gap-3 text-green-100 hover:text-white hover:bg-white/10 p-2 rounded transition"
                                                    href="#">
                                                    <span class="material-icons text-sm">lock</span> Serrature
                                                </a>
                                                <a class="flex items-center gap-3 text-green-100 hover:text-white hover:bg-white/10 p-2 rounded transition"
                                                    href="#">
                                                    <span class="material-icons text-sm">meeting_room</span> Stanze
                                                </a>
                                            </nav>
                                            <div class="mt-auto">
                                                <a class="flex items-center gap-3 text-green-100 hover:text-white p-2"
                                                    href="#">
                                                    <span class="material-icons text-sm">logout</span> Logout
                                                </a>
                                            </div>
                                            <% } %>
                            </div>

                            <!-- Calendar Content -->
                            <div class="flex-1 bg-gray-50 p-6 overflow-y-auto">
                                <div
                                    class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
                                    <div class="flex items-center gap-4">
                                        <h2 class="text-2xl font-bold text-gray-800">
                                            <%= (o4u && o4u.CalendarDate) || '' %>
                                        </h2>
                                        <div class="flex bg-white rounded-lg shadow-sm border border-gray-200">
                                            <button class="px-3 py-1 hover:bg-gray-50 border-r border-gray-200">
                                                <span class="material-icons text-gray-500 text-sm">
                                                    <%= (o4u && o4u.CalendarIcon) || '' %>
                                                </span>
                                            </button>
                                            <button
                                                class="px-3 py-1 text-sm font-medium text-gray-700 hover:bg-gray-50">
                                                <%= (o4u && o4u.CalendarOggi) || '' %>
                                            </button>
                                            <button class="px-3 py-1 hover:bg-gray-50 border-l border-gray-200">
                                                <span class="material-icons text-gray-500 text-sm">
                                                    <%= (o4u && o4u.CalendarIcon2) || '' %>
                                                </span>
                                            </button>
                                        </div>
                                    </div>
                                    <div class="relative w-full sm:w-auto">
                                        <span class="material-icons absolute left-3 top-2.5 text-gray-400 text-sm">
                                            <%= (o4u && o4u.CalendarIcon3) || '' %>
                                        </span>
                                        <input
                                            class="pl-9 pr-4 py-2 rounded-lg border border-gray-300 bg-white text-sm w-full focus:ring-2 focus:ring-primary focus:border-transparent text-gray-900"
                                            placeholder="Cerca stanze, risorse..." type="text" />
                                    </div>
                                </div>

                                <div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
                                    <div class="grid grid-cols-7 border-b border-gray-200 bg-gray-50">
                                        <div class="py-2 text-center text-xs font-semibold text-gray-500">LUN</div>
                                        <div class="py-2 text-center text-xs font-semibold text-gray-500">MAR</div>
                                        <div class="py-2 text-center text-xs font-semibold text-gray-500">MER</div>
                                        <div class="py-2 text-center text-xs font-semibold text-gray-500">GIO</div>
                                        <div class="py-2 text-center text-xs font-semibold text-gray-500">VEN</div>
                                        <div class="py-2 text-center text-xs font-semibold text-gray-500">SAB</div>
                                        <div class="py-2 text-center text-xs font-semibold text-gray-500">DOM</div>
                                    </div>
                                    <div class="grid grid-cols-7 auto-rows-fr bg-white h-[400px]">
                                        <div class="border-b border-r border-gray-100 p-2 text-gray-300 text-sm">24</div>
                                        <div class="border-b border-r border-gray-100 p-2 text-gray-300 text-sm">25</div>
                                        <div class="border-b border-r border-gray-100 p-1 min-h-[80px] relative group hover:bg-gray-50 transition">
                                            <span class="text-sm font-medium text-gray-700 ml-1">26</span>
                                            <div class="mt-1 bg-primary text-white text-[10px] px-1.5 py-0.5 rounded truncate shadow-sm">Ufficio Admin - Meeting</div>
                                            <div class="mt-1 bg-primary text-white text-[10px] px-1.5 py-0.5 rounded truncate shadow-sm opacity-80">Ufficio Admin - Setup</div>
                                        </div>
                                        <div class="border-b border-r border-gray-100 p-1 min-h-[80px] hover:bg-gray-50 transition">
                                            <span class="text-sm font-medium text-gray-700 ml-1">27</span>
                                            <div class="mt-1 bg-primary text-white text-[10px] px-1.5 py-0.5 rounded truncate shadow-sm">Sala Principale - Evento</div>
                                        </div>
                                        <div class="border-b border-r border-gray-100 p-1 min-h-[80px] hover:bg-gray-50 transition">
                                            <span class="text-sm font-medium text-gray-700 ml-1">28</span>
                                            <div class="mt-1 bg-primary text-white text-[10px] px-1.5 py-0.5 rounded truncate shadow-sm">Ufficio Admin - Check</div>
                                            <div class="mt-1 bg-purple-600 text-white text-[10px] px-1.5 py-0.5 rounded truncate shadow-sm">Palestra Basket - Training</div>
                                        </div>
                                        <div class="border-b border-r border-gray-100 p-1 min-h-[80px] bg-gray-50/50">
                                            <span class="text-sm font-medium text-gray-400 ml-1">1</span>
                                        </div>
                                        <div class="border-b border-gray-100 p-1 min-h-[80px] bg-gray-50/50">
                                            <span class="text-sm font-medium text-gray-400 ml-1">2</span>
                                        </div>
                                        <div class="border-b border-r border-gray-100 p-1 min-h-[80px]"><span class="text-sm text-gray-700 ml-1">3</span></div>
                                        <div class="border-b border-r border-gray-100 p-1 min-h-[80px]"><span class="text-sm text-gray-700 ml-1">4</span></div>
                                        <div class="border-b border-r border-gray-100 p-1 min-h-[80px]">
                                            <span class="text-sm text-gray-700 ml-1">5</span>
                                            <div class="mt-1 bg-red-700 text-white text-[10px] px-1.5 py-0.5 rounded truncate shadow-sm">Coworking B4US - Manutenzione</div>
                                        </div>
                                        <div class="border-b border-r border-gray-100 p-1 min-h-[80px]"><span class="text-sm text-gray-700 ml-1">6</span></div>
                                        <div class="border-b border-r border-gray-100 p-1 min-h-[80px]">
                                            <span class="text-sm text-gray-700 ml-1">7</span>
                                            <div class="mt-1 bg-primary text-white text-[10px] px-1.5 py-0.5 rounded truncate shadow-sm">Ufficio Admin - Visita</div>
                                        </div>
                                        <div class="border-b border-r border-gray-100 p-1 min-h-[80px] bg-gray-50/50">
                                            <span class="text-sm text-gray-400 ml-1">8</span>
                                        </div>
                                        <div class="border-b border-gray-100 p-1 min-h-[80px] bg-gray-50/50"><span class="text-sm text-gray-400 ml-1">9</span></div>
                                    </div>
                                </div>

                                <!-- Booking Detail Card -->
                                <% var cb=(o4u && o4u.CalendarBlock) ? o4u.CalendarBlock : null; %>
                                    <div
                                        class="mt-6 bg-white rounded-lg shadow-xl border border-gray-200 p-4 animate-bounce-in lg:max-w-md">
                                        <div class="flex justify-between items-start mb-3">
                                            <h3 class="font-bold text-gray-900">
                                                <%- (cb && cb.Title) || '' %>
                                            </h3>
                                            <span class="bg-green-100 text-primary text-xs font-bold px-2 py-1 rounded">
                                                <%= (cb && cb.Status) || '' %>
                                            </span>
                                        </div>
                                        <div class="space-y-2 text-sm text-gray-600">
                                            <div class="flex items-center gap-2">
                                                <span class="material-icons text-gray-400 text-sm">
                                                    <%= (cb && cb.Icon1) || '' %>
                                                </span>
                                                <%= (cb && cb.Date) || '' %>
                                            </div>
                                            <div class="flex items-center gap-2">
                                                <span class="material-icons text-gray-400 text-sm">
                                                    <%= (cb && cb.Icon2) || '' %>
                                                </span>
                                                <%= (cb && cb.Name) || '' %>
                                            </div>
                                            <div class="mt-3 p-2 bg-green-50 rounded border border-green-100">
                                                <div class="flex items-center gap-2 text-primary font-medium text-xs">
                                                    <span class="material-icons text-sm">
                                                        <%= (cb && cb.Icon3) || '' %>
                                                    </span>
                                                    <%= (cb && cb.Access) || '' %>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Use Cases Section -->
            <div class="py-24 bg-white">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                    <h2 class="text-3xl font-extrabold text-gray-900 text-center mb-12">
                        <%- (o4u && o4u.SpaceTitle) || '' %>
                    </h2>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                        <% if (o4u && o4u.SpaceBlock && o4u.SpaceBlock.length> 0) { %>
                            <% o4u.SpaceBlock.forEach(function(space) { %>
                                <div
                                    class="group p-8 bg-gray-50 rounded-2xl transition hover:shadow-xl hover:-translate-y-1 duration-300 border border-transparent hover:border-primary">
                                    <div
                                        class="w-14 h-14 bg-primary/10 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
                                        <span class="material-icons text-3xl text-primary">
                                            <%= space.Icon %>
                                        </span>
                                    </div>
                                    <h3 class="text-xl font-bold text-gray-900 mb-3">
                                        <%- space.Title %>
                                    </h3>
                                    <p class="text-gray-600 leading-relaxed">
                                        <% if (space.Description) { %>
                                            <%= space.Description %>
                                                <% } %>
                                    </p>
                                </div>
                                <% }); %>
                                    <% } else { %>
                                        <div
                                            class="group p-8 bg-gray-50 rounded-2xl transition hover:shadow-xl hover:-translate-y-1 duration-300 border border-transparent hover:border-primary">
                                            <div
                                                class="w-14 h-14 bg-primary/10 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
                                                <span
                                                    class="material-icons text-3xl text-primary">business_center</span>
                                            </div>
                                            <h3 class="text-xl font-bold text-gray-900 mb-3">Spazi di Coworking</h3>
                                            <p class="text-gray-600 leading-relaxed">Automatizza l'accesso ai membri.
                                                Concedi pass temporanei per sale riunioni e postazioni automaticamente
                                                dopo il pagamento della prenotazione.</p>
                                        </div>
                                        <div
                                            class="group p-8 bg-gray-50 rounded-2xl transition hover:shadow-xl hover:-translate-y-1 duration-300 border border-transparent hover:border-primary">
                                            <div
                                                class="w-14 h-14 bg-primary/10 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
                                                <span class="material-icons text-3xl text-primary">fitness_center</span>
                                            </div>
                                            <h3 class="text-xl font-bold text-gray-900 mb-3">Palestre & Centri Sportivi
                                            </h3>
                                            <p class="text-gray-600 leading-relaxed">Gestisci prenotazioni campi e
                                                ingressi in palestra. Imposta codici di accesso temporizzati per classi
                                                specifiche o slot di affitto.</p>
                                        </div>
                                        <div
                                            class="group p-8 bg-gray-50 rounded-2xl transition hover:shadow-xl hover:-translate-y-1 duration-300 border border-transparent hover:border-primary">
                                            <div
                                                class="w-14 h-14 bg-primary/10 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
                                                <span class="material-icons text-3xl text-primary">apartment</span>
                                            </div>
                                            <h3 class="text-xl font-bold text-gray-900 mb-3">Residenze & Uffici</h3>
                                            <p class="text-gray-600 leading-relaxed">Proteggi i tuoi edifici per uffici.
                                                Rilascia chiavi digitali ai dipendenti e accesso temporaneo al personale
                                                di manutenzione.</p>
                                        </div>
                                        <% } %>
                    </div>
                </div>
            </div>

            <!-- Luckey App Section -->
            <div class="py-24 bg-white overflow-hidden">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                    <div class="flex flex-col lg:flex-row items-center gap-16">
                        <div class="lg:w-1/2">
                            <div
                                class="rounded-2xl shadow-2xl overflow-hidden h-96 bg-gradient-to-br from-gray-100 to-gray-200 flex items-center justify-center">
                                <div class="text-center p-8">
                                    <span class="material-icons text-primary" style="font-size: 120px;">
                                        <%= (o4u && o4u.AppIcon && o4u.AppIcon.Icon) || '' %>
                                    </span>
                                    <p class="text-gray-500 mt-4 font-medium">
                                        <%= (o4u && o4u.AppIcon && o4u.AppIcon.Text)
                                            || '' %>
                                    </p>
                                </div>
                            </div>
                        </div>
                        <div class="lg:w-1/2">
                            <h2 class="text-3xl font-extrabold text-gray-900 mb-6">
                                <% if (o4u && o4u.AppTitle) { %>
                                    <%- o4u.AppTitle %>
                                        <% } else { %>
                                            Sblocca con l'App Open4US
                                            <% } %>
                            </h2>
                            <p class="text-lg text-gray-600 mb-6">
                                <% if (o4u && o4u.AppSubTitle) { %>
                                    <%- o4u.AppSubTitle %>
                                        <% } else { %>
                                            Dimentica le chiavi fisiche. Con la nostra perfetta integrazione con
                                            l'ecosistema Luckey, i tuoi utenti possono sbloccare le porte direttamente
                                            dal loro smartphone usando credenziali Bluetooth sicure.
                                            <% } %>
                            </p>
                            <ul class="space-y-4">
                                <% if (o4u && o4u.AppBlocks && o4u.AppBlocks.length> 0) { %>
                                    <% o4u.AppBlocks.forEach(function(block) { %>
                                        <li class="flex items-start">
                                            <span class="material-icons text-primary mr-3 mt-1">
                                                <%= block.Icon %>
                                            </span>
                                            <div>
                                                <h4 class="font-bold text-gray-900">
                                                    <%- block.Title %>
                                                </h4>
                                                <p class="text-gray-500 text-sm">
                                                    <%= block.Description %>
                                                </p>
                                            </div>
                                        </li>
                                        <% }); %>
                                            <% } else { %>
                                                <li class="flex items-start">
                                                    <span class="material-icons text-primary mr-3 mt-1">wifi_off</span>
                                                    <div>
                                                        <h4 class="font-bold text-gray-900">Funziona Offline</h4>
                                                        <p class="text-gray-500 text-sm">Le serrature smart verificano
                                                            le credenziali anche senza connessione internet.</p>
                                                    </div>
                                                </li>
                                                <li class="flex items-start">
                                                    <span class="material-icons text-primary mr-3 mt-1">share</span>
                                                    <div>
                                                        <h4 class="font-bold text-gray-900">Condivisione Intelligente
                                                        </h4>
                                                        <p class="text-gray-500 text-sm">Invia chiavi virtuali via email
                                                            o SMS istantaneamente.</p>
                                                    </div>
                                                </li>
                                                <li class="flex items-start">
                                                    <span class="material-icons text-primary mr-3 mt-1">history</span>
                                                    <div>
                                                        <h4 class="font-bold text-gray-900">Registro Accessi</h4>
                                                        <p class="text-gray-500 text-sm">Vedi esattamente chi è entrato
                                                            e quando dalla dashboard.</p>
                                                    </div>
                                                </li>
                                                <% } %>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <!-- CTA Section -->
            <div class="bg-gray-900 py-16">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                    <h2 class="text-3xl font-extrabold text-white mb-4">
                        <%- (o4u && o4u.ModernTitle) || '' %>
                    </h2>
                    <p class="text-xl text-gray-400 mb-8 max-w-2xl mx-auto">
                        <% if (o4u && o4u.ModernSubTitle) { %>
                            <%- o4u.ModernSubTitle %>
                                <% } else { %>
                                    Unisciti alle aziende che già usano Open4US per semplificare la gestione delle loro
                                    strutture.
                                    <% } %>
                    </p>
                    <div class="flex justify-center">
                        <button onclick="openDemoModal('Open4US')"
                            class="px-8 py-3 bg-primary text-white font-bold rounded-lg hover:bg-green-600 transition shadow-lg shadow-green-500/30">
                            <%= (o4u && o4u.ModernButton) || '' %>
                        </button>
                    </div>
                </div>
            </div>
        </main>

        <%- include('partials/demo-modal') %>
            <%- include('partials/footer') %>

        <script>
            (function(){var s=document.getElementById('page-skeleton');var c=document.getElementById('page-content');function show(){if(s)s.classList.add('hidden');if(c){c.classList.remove('hidden');c.classList.remove('opacity-0');}}if(document.readyState==='complete')show();else window.addEventListener('load',show);})();
        </script>
</body>

</html>