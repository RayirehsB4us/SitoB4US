<!DOCTYPE html>
<html class="scroll-smooth" lang="it">

<head>
  <%- include('partials/head') %>
</head>

<body class="bg-background-light text-slate-800 font-sans transition-colors duration-300">
<%- include('partials/topNav') %>
    <%- include('partials/skeleton-page') %>

    <main id="page-content" class="hidden opacity-0 transition-opacity duration-300">
    <section class="pt-32 pb-12 px-4">
      <div class="max-w-7xl mx-auto text-center">
        <h1 class="text-4xl md:text-6xl font-display font-bold mb-6">
          <%- sanitize(contattiData.MainTitle || '') %>
        </h1>
        <div class="text-lg text-slate-600 max-w-2xl mx-auto">
          <%- sanitize(contattiData.Description
            || '')
            %>
        </div>
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div
          class="bg-white dark:bg-slate-800/50 p-8 md:p-10 rounded-3xl shadow-xl shadow-slate-200/50 dark:shadow-none border border-slate-100 dark:border-slate-800">
          <h2 class="text-2xl font-display font-bold mb-8 flex items-center gap-2">
            <span class="material-symbols-outlined text-primary">send</span>
            <%- sanitize(contattiData.FormTitle || '') %>
          </h2>
          <form id="contactForm" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium mb-2" for="first-name">Nome *</label>
                <input
                  class="w-full px-4 py-3 rounded-xl bg-slate-50 dark:bg-slate-900 border-slate-200 dark:border-slate-700 focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none"
                  id="first-name" name="nome" placeholder="Mario" type="text" required />
              </div>
              <div>
                <label class="block text-sm font-medium mb-2" for="last-name">Cognome *</label>
                <input
                  class="w-full px-4 py-3 rounded-xl bg-slate-50 dark:bg-slate-900 border-slate-200 dark:border-slate-700 focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none"
                  id="last-name" name="cognome" placeholder="Rossi" type="text" required />
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium mb-2" for="company">Azienda *</label>
              <input
                class="w-full px-4 py-3 rounded-xl bg-slate-50 dark:bg-slate-900 border-slate-200 dark:border-slate-700 focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none"
                id="company" name="azienda" placeholder="La tua azienda" type="text" required />
            </div>
            <div>
              <label class="block text-sm font-medium mb-2" for="email">Email Aziendale *</label>
              <input
                class="w-full px-4 py-3 rounded-xl bg-slate-50 dark:bg-slate-900 border-slate-200 dark:border-slate-700 focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none"
                id="email" name="email" placeholder="m.rossi@azienda.it" type="email" required />
            </div>
            <div>
              <label class="block text-sm font-medium mb-2" for="subject">Oggetto *</label>
              <select
                class="w-full px-4 py-3 rounded-xl bg-slate-50 dark:bg-slate-900 border-slate-200 dark:border-slate-700 focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none appearance-none"
                id="subject" name="softwareProduct" required>
                <option value="">Seleziona un'opzione</option>
                <option value="Consulenza IT">Consulenza IT</option>
                <option value="Opportunità di Lavoro">Opportunità di Lavoro</option>
                <option value="Altro">Altro</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium mb-2" for="message">Messaggio</label>
              <textarea
                class="w-full px-4 py-3 rounded-xl bg-slate-50 dark:bg-slate-900 border-slate-200 dark:border-slate-700 focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none"
                id="message" name="messaggio" placeholder="Come possiamo aiutarti?" rows="4"></textarea>
            </div>

            <!-- Success Message -->
            <div id="contactSuccessMessage"
              class="hidden bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-xl relative">
              <span class="flex items-center">
                <span class="material-symbols-outlined mr-2">check_circle</span>
                <span>Richiesta inviata con successo! Ti contatteremo presto.</span>
              </span>
            </div>

            <!-- Error Message -->
            <div id="contactErrorMessage"
              class="hidden bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-xl relative">
              <span class="flex items-center">
                <span class="material-symbols-outlined mr-2">error</span>
                <span id="contactErrorText">Si è verificato un errore. Riprova.</span>
              </span>
            </div>

            <button id="contactSubmitBtn"
              class="w-full py-4 bg-primary hover:bg-emerald-700 text-white font-bold rounded-xl shadow-lg shadow-primary/20 transition-all transform hover:-translate-y-0.5 active:translate-y-0 flex items-center justify-center"
              type="submit">
              <span id="contactSubmitText">Invia Richiesta</span>
              <span id="contactSubmitLoader" class="hidden material-symbols-outlined animate-spin ml-2">sync</span>
            </button>
          </form>
        </div>
        <div class="space-y-8">
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            <% if (contattiData.ContactDetails && contattiData.ContactDetails.length> 0) { %>
              <% contattiData.ContactDetails.forEach(function(detail) { %>
                <div
                  class="p-6 rounded-3xl bg-white dark:bg-slate-800/50 border border-slate-100 dark:border-slate-800 shadow-sm">
                  <div class="w-12 h-12 bg-primary/10 rounded-2xl flex items-center justify-center mb-4">
                    <span class="material-symbols-outlined text-primary">
                      <%= detail.icon || '' %>
                    </span>
                  </div>
                  <h3 class="font-display font-bold text-lg mb-1">
                    <%- sanitize(detail.title) %>
                  </h3>
                  <p class="text-slate-500 dark:text-slate-400 text-sm mb-2">
                    <%- sanitize(detail.subTitle) %>
                  </p>
                  <a class="text-primary font-bold hover:underline text-sm" href="<%= detail.linkUrl || '#' %>">
                    <%= detail.linkText %>
                  </a>
                </div>
                <% }); %>
                  <% } else { %>
                    <div
                      class="p-6 rounded-3xl bg-white dark:bg-slate-800/50 border border-slate-100 dark:border-slate-800 shadow-sm">
                      <div class="w-12 h-12 bg-primary/10 rounded-2xl flex items-center justify-center mb-4">
                        <span class="material-symbols-outlined text-primary">phone_in_talk</span>
                      </div>
                      <h3 class="font-display font-bold text-lg mb-1">Chiamaci</h3>
                      <p class="text-slate-500 dark:text-slate-400 text-sm mb-2">Lun-Ven dalle 9:00 alle 18:00</p>
                      <a class="text-primary font-bold hover:underline text-sm" href="tel:+390236647728">+39 02
                        36647728</a>
                    </div>
                    <div
                      class="p-6 rounded-3xl bg-white dark:bg-slate-800/50 border border-slate-100 dark:border-slate-800 shadow-sm">
                      <div class="w-12 h-12 bg-primary/10 rounded-2xl flex items-center justify-center mb-4">
                        <span class="material-symbols-outlined text-primary">mail</span>
                      </div>
                      <h3 class="font-display font-bold text-lg mb-1">Scrivici</h3>
                      <p class="text-slate-500 dark:text-slate-400 text-sm mb-2">Ti risponderemo entro 24h</p>
                      <a class="text-primary font-bold hover:underline" href="mailto:info@b4us.it">info@b4us.it</a>
                    </div>
                    <div
                      class="p-6 rounded-3xl bg-white dark:bg-slate-800/50 border border-slate-100 dark:border-slate-800 shadow-sm sm:col-span-2 lg:col-span-1">
                      <div class="w-12 h-12 bg-primary/10 rounded-2xl flex items-center justify-center mb-4">
                        <span class="material-symbols-outlined text-primary">groups</span>
                      </div>
                      <h3 class="font-display font-bold text-lg mb-1">LinkedIn</h3>
                      <p class="text-slate-500 dark:text-slate-400 text-sm mb-2">News, eventi e vita aziendale</p>
                      <a class="text-primary font-bold hover:underline inline-flex items-center gap-1"
                        href="https://www.linkedin.com/company/b4us" target="_blank" rel="noopener noreferrer">
                        B4US
                        <span class="material-symbols-outlined text-sm">open_in_new</span>
                      </a>
                    </div>
                    <% } %>
          </div>
          <div
            class="p-8 rounded-3xl bg-white dark:bg-slate-800/50 border border-slate-100 dark:border-slate-800 shadow-sm">
            <div class="flex items-start gap-4 mb-6">
              <div class="w-12 h-12 flex-shrink-0 bg-primary/10 rounded-2xl flex items-center justify-center">
                <span class="material-symbols-outlined text-primary">location_on</span>
              </div>
              <div>
                <h3 class="font-display font-bold text-lg mb-1">
                  <%- sanitize(contattiData.SedeTitle || '') %>
                </h3>
                <p class="text-slate-500 dark:text-slate-400">
                  <%= contattiData.SedeAddress || '' %>
                </p>
              </div>
            </div>
            <div
              class="relative w-full h-[300px] rounded-2xl overflow-hidden shadow-inner bg-slate-200 dark:bg-slate-700">
              <iframe
                src="<%= contattiData.SedeMapUrl || 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2795.8573762744447!2d9.401682976519436!3d45.52766367107462!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4786c0f5e5e5e5e5%3A0x5e5e5e5e5e5e5e5e!2sVia%20Vincenzo%20Pessina%2C%202%2C%2020064%20Gorgonzola%20MI!5e0!3m2!1sit!2sit!4v1000000000000!5m2!1sit!2sit' %>"
                width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy"
                referrerpolicy="no-referrer-when-downgrade" class="w-full h-full"
                title="Mappa sede B4US - Via Vincenzo Pessina, 2, Gorgonzola"></iframe>
            </div>
          </div>
        </div>
      </div>
    </section>
    </main>

    <%- include('partials/footer') %>

      <script>
        // Handle contact form submission
        document.getElementById('contactForm')?.addEventListener('submit', async function (e) {
          e.preventDefault();

          const submitBtn = document.getElementById('contactSubmitBtn');
          const submitText = document.getElementById('contactSubmitText');
          const submitLoader = document.getElementById('contactSubmitLoader');
          const successMessage = document.getElementById('contactSuccessMessage');
          const errorMessage = document.getElementById('contactErrorMessage');
          const errorText = document.getElementById('contactErrorText');

          // Hide messages
          successMessage.classList.add('hidden');
          errorMessage.classList.add('hidden');

          // Show loader
          submitBtn.disabled = true;
          submitText.classList.add('hidden');
          submitLoader.classList.remove('hidden');

          const formData = {
            nome: document.getElementById('first-name').value,
            cognome: document.getElementById('last-name').value,
            azienda: document.getElementById('company').value,
            email: document.getElementById('email').value,
            softwareProduct: document.getElementById('subject').value,
            messaggio: document.getElementById('message').value || null
          };

          try {
            const response = await fetch('/api/demo-request', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify(formData)
            });

            const data = await response.json();

            if (data.success) {
              successMessage.classList.remove('hidden');
              document.getElementById('contactForm').reset();

              // Scroll to success message
              successMessage.scrollIntoView({
                behavior: 'smooth',
                block: 'center'
              });
            } else {
              errorText.textContent = data.message || 'Si è verificato un errore. Riprova.';
              errorMessage.classList.remove('hidden');
              errorMessage.scrollIntoView({
                behavior: 'smooth',
                block: 'center'
              });
            }
          } catch (error) {
            console.error('Error:', error);
            errorText.textContent = 'Si è verificato un errore. Riprova.';
            errorMessage.classList.remove('hidden');
            errorMessage.scrollIntoView({
              behavior: 'smooth',
              block: 'center'
            });
          } finally {
            // Hide loader
            submitBtn.disabled = false;
            submitText.classList.remove('hidden');
            submitLoader.classList.add('hidden');
          }
        });
      </script>
      <script>
        (function(){var s=document.getElementById('page-skeleton');var c=document.getElementById('page-content');function show(){if(s)s.classList.add('hidden');if(c){c.classList.remove('hidden');c.classList.remove('opacity-0');}}if(document.readyState==='complete')show();else window.addEventListener('load',show);})();
      </script>
</body>

</html>