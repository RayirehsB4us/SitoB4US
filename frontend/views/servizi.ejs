<!DOCTYPE html>
<html class="scroll-smooth" lang="it">

<head>
    <%- include('partials/head') %>
</head>

<body class="bg-background-light text-slate-800 font-sans transition-colors duration-300">
    <%- include('partials/topNav') %>
    <%- include('partials/skeleton-page') %>

        <main id="page-content" class="hidden opacity-0 transition-opacity duration-300">
        <section
            class="py-20 lg:py-28 bg-gradient-to-b from-white to-slate-50 dark:from-background-dark dark:to-slate-900 overflow-hidden">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
                <div class="max-w-3xl">
                    <h1 class="font-display text-4xl md:text-6xl font-bold tracking-tight mb-6">
                        <% if (serviziPage && serviziPage.Maintitle) { %>
                            <%- serviziPage.Maintitle %>
                        <% } else { %>
                            Soluzioni IT <span class="text-primary">su misura</span> per il tuo business.
                        <% } %>
                    </h1>
                    <div class="text-lg md:text-xl text-slate-600 dark:text-slate-400 leading-relaxed mb-10">
                        <%- (serviziPage && serviziPage.descriptiontitle) || '' %>
                    </div>
                    <div class="flex flex-wrap gap-4">
                        <a class="px-8 py-4 bg-primary text-white font-bold rounded-xl hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
                            href="#servizi-grid">
                            <%= (serviziPage && serviziPage.ButtonServizi) || '' %>
                        </a>
                        <a class="px-8 py-4 bg-white dark:bg-slate-800 text-slate-900 dark:text-white border border-slate-200 dark:border-slate-700 font-bold rounded-xl hover:bg-slate-50 dark:hover:bg-slate-700 transition-all duration-300"
                            href="/contatti">
                            <%= (serviziPage && serviziPage.ButtonContatti) || '' %>
                        </a>
                    </div>
                </div>
                <div class="absolute -top-24 -right-24 w-96 h-96 bg-primary/10 rounded-full blur-3xl -z-10"></div>
                <div class="absolute bottom-0 right-1/4 w-64 h-64 bg-blue-500/10 rounded-full blur-3xl -z-10"></div>
            </div>
        </section>
        <section class="py-24 bg-white dark:bg-background-dark" id="servizi-grid">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-16">
                    <% var skills = serviziPage.OurSkills && serviziPage.OurSkills[0]; %>
                    <span class="text-primary font-bold tracking-widest uppercase text-sm"><%= (skills && skills.Tag) || '' %></span>
                    <h2 class="font-display text-3xl md:text-4xl font-bold mt-3"><%- (skills && skills.Title) || '' %></h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    <% if (servizi && servizi.length> 0) { %>
                        <% servizi.forEach(function(servizio) { %>
                            <div
                                class="group p-8 rounded-2xl bg-slate-50 dark:bg-slate-800/50 border border-slate-100 dark:border-slate-800 hover:bg-white dark:hover:bg-slate-800 hover:shadow-2xl hover:shadow-primary/10 hover:-translate-y-2 transition-all duration-300">
                                <div
                                    class="w-14 h-14 bg-primary/10 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
                                    <span class="material-symbols-outlined text-primary text-3xl">
                                        <%= servizio.icona || '' %>
                                    </span>
                                </div>
                                <h3 class="font-display text-xl font-bold mb-4">
                                    <%- servizio.titolo %>
                                </h3>
                                <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-6">
                                    <%= servizio.descrizione %>
                                </p>
                            </div>
                            <% }); %>
                                <% } else { %>
                                    <!-- Fallback -->
                                    <div
                                        class="group p-8 rounded-2xl bg-slate-50 dark:bg-slate-800/50 border border-slate-100 dark:border-slate-800 hover:bg-white dark:hover:bg-slate-800 hover:shadow-2xl hover:shadow-primary/10 hover:-translate-y-2 transition-all duration-300">
                                        <div
                                            class="w-14 h-14 bg-primary/10 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
                                            <span
                                                class="material-symbols-outlined text-primary text-3xl">cloud_queue</span>
                                        </div>
                                        <h3 class="font-display text-xl font-bold mb-4">Nessun servizio disponibile</h3>
                                        <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-6">
                                            Configura i servizi in Strapi.
                                        </p>
                                    </div>
                                    <% } %>
                </div>
            </div>
        </section>
        </main>
        <%- include('partials/footer') %>

        <script>
            (function(){var s=document.getElementById('page-skeleton');var c=document.getElementById('page-content');function show(){if(s)s.classList.add('hidden');if(c){c.classList.remove('hidden');c.classList.remove('opacity-0');}}if(document.readyState==='complete')show();else window.addEventListener('load',show);})();
        </script>
</body>

</html>