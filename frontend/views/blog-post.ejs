<!DOCTYPE html>
<html class="scroll-smooth" lang="it">

<head>
  <%- include('partials/head') %>
    <style>
      /* Stili per il contenuto richtext */
      .prose h1 { @apply text-3xl font-bold mb-6 mt-10 text-slate-900; }
      .prose h2 { @apply text-2xl font-bold mb-4 mt-8 text-slate-900; }
      .prose h3 { @apply text-xl font-bold mb-3 mt-6 text-slate-900; }
      .prose h4 { @apply text-lg font-bold mb-2 mt-4 text-slate-900; }
      .prose p { @apply mb-4 leading-relaxed; }
      .prose ul { @apply list-disc list-inside mb-4 space-y-2; }
      .prose ol { @apply list-decimal list-inside mb-4 space-y-2; }
      .prose li { @apply text-slate-600; }
      .prose a { @apply text-primary hover:underline; }
      .prose blockquote { 
        @apply border-l-4 border-primary pl-6 py-2 my-6 italic text-slate-600 bg-slate-50 rounded-r-xl;
      }
      .prose code { @apply bg-slate-100 px-2 py-1 rounded text-sm font-mono text-primary; }
      .prose pre { @apply bg-slate-900 text-slate-100 p-6 rounded-xl mb-6 overflow-x-auto; }
      .prose pre code { @apply bg-transparent p-0 text-slate-100; }
      .prose img { @apply rounded-xl my-6 shadow-lg; }
      .prose strong { @apply font-bold text-slate-800; }
      .prose em { @apply italic; }
      .prose hr { @apply my-8 border-slate-200; }
    </style>
</head>

<body class="bg-background-light text-slate-900 font-sans transition-colors duration-300">
  <%- include('partials/topNav') %>
  <%- include('partials/skeleton-page') %>

    <main id="page-content" class="hidden opacity-0 transition-opacity duration-300">
    <% if (post) { %>
      <!-- Hero con immagine -->
      <header class="relative">
        <% if (post.immagine) { %>
          <div class="relative h-[50vh] md:h-[60vh] overflow-hidden">
            <img
              alt="<%= post.titolo %>"
              class="w-full h-full object-cover"
              src="<%= strapiUrl %><%= post.immagine.url %>" 
            />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/90 via-slate-900/40 to-transparent"></div>
          </div>
        <% } else { %>
          <div class="relative h-[40vh] bg-gradient-to-br from-primary to-green-600 overflow-hidden">
            <div class="absolute inset-0 opacity-20">
              <div class="absolute top-10 right-10 w-64 h-64 border-8 border-white rounded-full"></div>
              <div class="absolute bottom-10 left-10 w-40 h-40 bg-white rounded-full"></div>
            </div>
          </div>
        <% } %>
        
        <!-- Contenuto header sovrapposto -->
        <div class="absolute bottom-0 left-0 right-0 pb-12 pt-20">
          <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <% if (post.categoria) { %>
              <span class="inline-block bg-primary text-white px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-4">
                <%= post.categoria %>
              </span>
            <% } %>
            <h1 class="text-3xl md:text-5xl font-display font-bold text-white leading-tight mb-6">
              <%= post.titolo %>
            </h1>
            <div class="flex flex-wrap items-center gap-6 text-white/80 text-sm">
              <% if (post.dataPublicazione) { %>
                <span class="flex items-center gap-2">
                  <span class="material-symbols-outlined text-lg">calendar_today</span>
                  <%= new Date(post.dataPublicazione).toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' }) %>
                </span>
              <% } %>
              <% if (post.tempoLettura) { %>
                <span class="flex items-center gap-2">
                  <span class="material-symbols-outlined text-lg">schedule</span>
                  <%= post.tempoLettura %> min di lettura
                </span>
              <% } %>
            </div>
          </div>
        </div>
      </header>

      <!-- Contenuto articolo -->
      <article class="py-16">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
          <!-- Descrizione/intro -->
          <div class="mb-10 pb-10 border-b border-slate-200">
            <p class="text-xl text-slate-600 leading-relaxed italic">
              <%= post.descrizione %>
            </p>
          </div>

          <!-- Contenuto principale -->
          <% if (post.contenuto) { %>
            <div class="prose max-w-none text-slate-600">
              <%- post.contenuto %>
            </div>
          <% } else { %>
            <div class="text-center py-12 bg-slate-50 rounded-2xl">
              <span class="material-symbols-outlined text-4xl text-slate-400 mb-4">article</span>
              <p class="text-slate-500">Contenuto in arrivo...</p>
            </div>
          <% } %>

          <!-- Share e navigazione -->
          <div class="mt-16 pt-10 border-t border-slate-200">
            <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
              <div>
                <p class="text-sm text-slate-500 mb-3">Condividi questo articolo</p>
                <div class="flex gap-3">
                  <a href="https://www.linkedin.com/shareArticle?mini=true&url=<%= encodeURIComponent('https://b4us.it/blog/' + post.slug) %>&title=<%= encodeURIComponent(post.titolo) %>" 
                     target="_blank"
                     class="w-10 h-10 bg-slate-100 hover:bg-primary hover:text-white rounded-xl flex items-center justify-center transition-all">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                  </a>
                  <a href="https://twitter.com/intent/tweet?text=<%= encodeURIComponent(post.titolo) %>&url=<%= encodeURIComponent('https://b4us.it/blog/' + post.slug) %>" 
                     target="_blank"
                     class="w-10 h-10 bg-slate-100 hover:bg-primary hover:text-white rounded-xl flex items-center justify-center transition-all">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                  </a>
                  <button onclick="navigator.clipboard.writeText(window.location.href); this.innerHTML='<span class=\'material-symbols-outlined\'>check</span>'; setTimeout(() => this.innerHTML='<span class=\'material-symbols-outlined\'>link</span>', 2000)"
                          class="w-10 h-10 bg-slate-100 hover:bg-primary hover:text-white rounded-xl flex items-center justify-center transition-all">
                    <span class="material-symbols-outlined">link</span>
                  </button>
                </div>
              </div>
              <a href="/blog" class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white font-bold rounded-xl hover:bg-green-600 transition-all">
                <span class="material-symbols-outlined">arrow_back</span>
                Torna al Blog
              </a>
            </div>
          </div>
        </div>
      </article>

    <% } else { %>
      <!-- Articolo non trovato -->
      <section class="py-32">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
          <div class="w-24 h-24 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-8">
            <span class="material-symbols-outlined text-5xl text-slate-400">search_off</span>
          </div>
          <h1 class="text-3xl font-bold text-slate-900 mb-4">Articolo non trovato</h1>
          <p class="text-slate-600 mb-10">L'articolo che stai cercando non esiste o è stato rimosso.</p>
          <a href="/blog" class="inline-flex items-center gap-2 px-8 py-4 bg-primary text-white font-bold rounded-xl hover:bg-green-600 transition-all">
            <span class="material-symbols-outlined">arrow_back</span>
            Torna al Blog
          </a>
        </div>
      </section>
    <% } %>

    <!-- Articoli correlati -->
    <% if (post && relatedPosts && relatedPosts.length > 0) { %>
      <section class="py-20 bg-slate-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <h2 class="text-2xl font-bold mb-10">Altri articoli che potrebbero interessarti</h2>
          <div class="grid md:grid-cols-3 gap-8">
            <% relatedPosts.slice(0, 3).forEach(function(related) { %>
              <article class="group bg-white rounded-2xl overflow-hidden shadow-sm border border-slate-100 hover:shadow-xl transition-all">
                <div class="relative overflow-hidden aspect-[16/10]">
                  <% if (related.immagine) { %>
                    <img alt="<%= related.titolo %>"
                      class="object-cover w-full h-full group-hover:scale-110 transition-transform duration-500"
                      src="<%= strapiUrl %><%= related.immagine.url %>" />
                  <% } else { %>
                    <div class="w-full h-full bg-gradient-to-br from-primary to-green-600 flex items-center justify-center">
                      <span class="text-white text-4xl font-bold"><%= related.titolo.charAt(0) %></span>
                    </div>
                  <% } %>
                </div>
                <div class="p-6">
                  <h3 class="text-lg font-bold mb-2 group-hover:text-primary transition-colors line-clamp-2">
                    <%= related.titolo %>
                  </h3>
                  <p class="text-slate-600 text-sm line-clamp-2 mb-4"><%= related.descrizione %></p>
                  <a href="/blog/<%= related.slug %>" class="inline-flex items-center text-primary font-semibold text-sm">
                    Leggi
                    <span class="material-symbols-outlined text-base ml-1">arrow_forward</span>
                  </a>
                </div>
              </article>
            <% }); %>
          </div>
        </div>
      </section>
    <% } %>
    </main>

    <%- include('partials/footer') %>

    <script>
        (function(){var s=document.getElementById('page-skeleton');var c=document.getElementById('page-content');function show(){if(s)s.classList.add('hidden');if(c){c.classList.remove('hidden');c.classList.remove('opacity-0');}}if(document.readyState==='complete')show();else window.addEventListener('load',show);})();
    </script>
</body>

</html>

