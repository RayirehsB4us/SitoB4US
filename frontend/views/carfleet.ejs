<!DOCTYPE html>
<html class="scroll-smooth" lang="it">

<head>
    <%- include('partials/head') %>
        <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
        <style>
            @keyframes float {

                0%,
                100% {
                    transform: translateY(0px);
                }

                50% {
                    transform: translateY(-20px);
                }
            }

            .float-animation {
                animation: float 6s ease-in-out infinite;
            }

            .card-hover {
                transition: all 0.3s ease;
            }

            .card-hover:hover {
                transform: translateY(-5px);
                box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);
            }
        </style>
</head>

<body class="bg-background-light text-secondary font-sans transition-colors duration-300">
    <%- include('partials/navbar') %>

        <main class="pt-16">
            <!-- Hero Section -->
            <div class="relative overflow-hidden py-16 lg:py-24">
                <div class="max-w-7xl mx-auto">
                    <div class="grid lg:grid-cols-2 gap-12 items-center px-4 sm:px-6 lg:px-8">
                        <!-- Left Content -->
                        <div>
                            <div
                                class="inline-flex items-center px-3 py-1 rounded-full bg-green-100 text-primary text-xs font-semibold tracking-wide uppercase mb-6">
                                <span class="material-icons text-sm mr-1"><%= cf.Icon || 'directions_car' %></span>
                                <%= cf.UpperTitle || 'Gestione Flotta Aziendale' %>
                            </div>
                            <h1 class="text-4xl lg:text-6xl font-extrabold tracking-tight text-gray-900 mb-6">
                                <% if (cf.Title) { %>
                                    <span class="text-secondary"><%= cf.Title %></span>
                                    <span class="text-primary"><%= cf.Title2 || 'aziendale con intelligenza' %></span>
                                <% } else { %>
                                    <span class="text-secondary">Gestisci la tua flotta</span>
                                    <span class="text-primary">aziendale con intelligenza</span>
                                <% } %>
                            </h1>
                            <p class="text-lg text-gray-600 mb-8 leading-relaxed">
                                <% if (cf.SubTitle) { %>
                                    <%= cf.SubTitle %>
                                <% } else { %>
                                    Gestisci prenotazioni in modo efficiente, traccia i veicoli in tempo reale e automatizza
                                    gli accessi con la nostra soluzione personalizzata su PowerApps. Semplifica le
                                    operazioni della tua flotta oggi stesso.
                                <% } %>
                            </p>
                            <div class="flex flex-col sm:flex-row gap-4">
                                <button onclick="openDemoModal('CarFleet')"
                                    class="flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-lg text-white bg-primary hover:bg-green-600 md:text-lg shadow-lg shadow-green-500/40 transition-transform transform hover:-translate-y-1">
                                    <%= cf.Button1 || 'Prenota una Demo' %>
                                    <span class="material-icons ml-2">arrow_forward</span>
                                </button>
                                <a href="#funzionalita"
                                    class="flex items-center justify-center px-8 py-3 border border-gray-300 text-base font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 md:text-lg transition-colors">
                                    <%= cf.Button2 || 'Scopri le Funzionalità' %>
                                </a>
                            </div>
                            <div class="mt-8 flex flex-wrap items-center gap-6 text-gray-400 text-sm font-medium">
                                <% if (cf.IconText && cf.IconText.length > 0) { %>
                                    <% cf.IconText.forEach(function(item) { %>
                                        <div class="flex items-center gap-1">
                                            <span class="material-icons text-primary text-base"><%= item.Icon || 'check_circle' %></span> <%= item.Text %>
                                        </div>
                                    <% }); %>
                                <% } else { %>
                                    <div class="flex items-center gap-1">
                                        <span class="material-icons text-primary text-base">check_circle</span> Tracciamento GPS
                                    </div>
                                    <div class="flex items-center gap-1">
                                        <span class="material-icons text-primary text-base">check_circle</span> PowerApps Integration
                                    </div>
                                    <div class="flex items-center gap-1">
                                        <span class="material-icons text-primary text-base">check_circle</span> Accesso Automatico
                                    </div>
                                <% } %>
                            </div>
                        </div>

                        <!-- Right Content - Dashboard Preview -->
                        <div class="relative">
                            <div
                                class="absolute top-0 right-0 -mr-20 -mt-20 w-72 h-72 bg-primary opacity-20 blur-3xl rounded-full">
                            </div>
                            <div class="relative z-10">
                                <div
                                    class="bg-white rounded-2xl shadow-2xl overflow-hidden border border-gray-100 card-hover">
                                    <% if (cf.Image) { %>
                                        <img src="<%= strapiUrl + cf.Image.url %>"
                                            alt="<%= cf.Image.alternativeText || 'Dashboard CarFleet - Gestione Flotta Aziendale' %>"
                                            class="w-full h-auto object-cover">
                                    <% } else { %>
                                        <img src="/images/carfleet-dashboard.png"
                                            alt="Dashboard CarFleet - Gestione Flotta Aziendale"
                                            class="w-full h-auto object-cover">
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Dashboard Overview Section -->
            <section class="py-16 bg-gray-50">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                    <div class="text-center mb-12">
                        <p class="text-base text-primary font-semibold tracking-wide uppercase"><%= cf.UpperTitle2 || 'Panoramica Dashboard' %></p>
                        <h2 class="mt-2 text-3xl leading-8 font-extrabold tracking-tight text-gray-900 sm:text-4xl">
                            <% if (cf.Title3) { %>
                                <%= cf.Title3 %>
                            <% } else { %>
                                Informazioni in tempo reale a colpo d'occhio
                            <% } %>
                        </h2>
                        <p class="mt-4 max-w-2xl text-xl text-gray-500 mx-auto">
                            <%= cf.SubTitle2 || 'Monitora ogni aspetto della tua flotta con metriche chiare e actionable' %>
                        </p>
                    </div>

                    <% var cardStyles = [
                        { border: 'border-primary', bg: 'bg-red-100', text: 'text-red-600' },
                        { border: 'border-primary', bg: 'bg-green-100', text: 'text-green-600' },
                        { border: 'border-primary', bg: 'bg-yellow-100', text: 'text-yellow-600' },
                        { border: 'border-blue-500', bg: 'bg-blue-100', text: 'text-blue-600' },
                        { border: 'border-orange-500', bg: 'bg-orange-100', text: 'text-orange-600' },
                        { border: 'border-gray-500', bg: 'bg-gray-100', text: 'text-gray-600' }
                    ]; %>
                    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
                        <% if (cf.DashboardPanoramica && cf.DashboardPanoramica.length > 0) { %>
                            <% cf.DashboardPanoramica.forEach(function(card, idx) { %>
                                <% var style = cardStyles[idx % cardStyles.length]; %>
                                <div class="bg-white overflow-hidden shadow rounded-lg hover:shadow-lg transition-shadow duration-300 border-t-4 <%= style.border %>">
                                    <div class="px-4 py-5 sm:p-6">
                                        <div class="flex items-center">
                                            <div class="flex-shrink-0 <%= style.bg %> rounded-md p-3">
                                                <span class="material-icons <%= style.text %>"><%= card.icon %></span>
                                            </div>
                                            <div class="ml-5 w-0 flex-1">
                                                <dl>
                                                    <dt class="text-sm font-medium text-gray-500 truncate"><%= card.title %></dt>
                                                    <dd>
                                                        <div class="text-3xl font-bold text-gray-900"><%= card.subTitle %></div>
                                                    </dd>
                                                </dl>
                                            </div>
                                        </div>
                                        <div class="mt-4">
                                            <p class="text-sm text-gray-500"><%= card.content %></p>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <div class="bg-white overflow-hidden shadow rounded-lg hover:shadow-lg transition-shadow duration-300 border-t-4 border-primary">
                                <div class="px-4 py-5 sm:p-6">
                                    <div class="flex items-center">
                                        <div class="flex-shrink-0 bg-red-100 rounded-md p-3">
                                            <span class="material-icons text-red-600">priority_high</span>
                                        </div>
                                        <div class="ml-5 w-0 flex-1">
                                            <dl>
                                                <dt class="text-sm font-medium text-gray-500 truncate">Validazioni Prenotazioni</dt>
                                                <dd><div class="text-3xl font-bold text-gray-900">3</div></dd>
                                            </dl>
                                        </div>
                                    </div>
                                    <div class="mt-4"><p class="text-sm text-gray-500">Elementi ad alta priorità che richiedono attenzione.</p></div>
                                </div>
                            </div>
                            <div class="bg-white overflow-hidden shadow rounded-lg hover:shadow-lg transition-shadow duration-300 border-t-4 border-primary">
                                <div class="px-4 py-5 sm:p-6">
                                    <div class="flex items-center">
                                        <div class="flex-shrink-0 bg-green-100 rounded-md p-3">
                                            <span class="material-icons text-green-600">calendar_today</span>
                                        </div>
                                        <div class="ml-5 w-0 flex-1">
                                            <dl>
                                                <dt class="text-sm font-medium text-gray-500 truncate">Prenotazioni Correnti</dt>
                                                <dd><div class="text-3xl font-bold text-gray-900">5</div></dd>
                                            </dl>
                                        </div>
                                    </div>
                                    <div class="mt-4"><p class="text-sm text-gray-500">Approvate con successo e pianificate.</p></div>
                                </div>
                            </div>
                            <div class="bg-white overflow-hidden shadow rounded-lg hover:shadow-lg transition-shadow duration-300 border-t-4 border-primary">
                                <div class="px-4 py-5 sm:p-6">
                                    <div class="flex items-center">
                                        <div class="flex-shrink-0 bg-yellow-100 rounded-md p-3">
                                            <span class="material-icons text-yellow-600">schedule</span>
                                        </div>
                                        <div class="ml-5 w-0 flex-1">
                                            <dl>
                                                <dt class="text-sm font-medium text-gray-500 truncate">Rientri Ritardati</dt>
                                                <dd><div class="text-3xl font-bold text-gray-900">1</div></dd>
                                            </dl>
                                        </div>
                                    </div>
                                    <div class="mt-4"><p class="text-sm text-gray-500">Veicoli non riconsegnati in tempo.</p></div>
                                </div>
                            </div>
                        <% } %>
                    </div>
                </div>
            </section>

            <!-- Features Section -->
            <section id="funzionalita" class="py-16 lg:py-24">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                    <div class="text-center mb-16">
                        <h2 class="text-3xl leading-8 font-extrabold tracking-tight text-gray-900 sm:text-4xl">
                            <%= cf.Title4 || 'Gestione Flotta Intelligente' %>
                        </h2>
                        <p class="mt-4 max-w-3xl mx-auto text-xl text-gray-500">
                            <% if (cf.SubTitle3) { %>
                                <%= cf.SubTitle3 %>
                            <% } else { %>
                                CarFleet integra hardware e software avanzati per fornire un'esperienza senza interruzioni
                                sia ai gestori che ai conducenti.
                            <% } %>
                        </p>
                    </div>

                    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center mb-24">
                        <!-- Text Content -->
                        <div>
                            <h3 class="text-2xl font-extrabold text-gray-900 tracking-tight sm:text-3xl mb-4">
                                <%= cf.Title5 || 'Integrazione PowerApps' %>
                            </h3>
                            <p class="text-lg text-gray-600 mb-8 leading-relaxed">
                                <% if (cf.Subtitle4) { %>
                                    <%= cf.Subtitle4 %>
                                <% } else { %>
                                    Costruita sulla robusta piattaforma PowerApps, la nostra soluzione offre flessibilità e
                                    sicurezza. Personalizza i flussi di lavoro, gestisce i permessi e si integra
                                    perfettamente con il tuo ecosistema aziendale esistente.
                                <% } %>
                            </p>

                            <div class="space-y-6">
                                <% if (cf.PowerappsBlocks && cf.PowerappsBlocks.length > 0) { %>
                                    <% cf.PowerappsBlocks.forEach(function(block) { %>
                                        <div class="flex items-start">
                                            <div
                                                class="flex-shrink-0 h-12 w-12 rounded-md bg-primary text-white flex items-center justify-center">
                                                <span class="material-icons"><%= block.Icon %></span>
                                            </div>
                                            <div class="ml-4">
                                                <h4 class="text-lg leading-6 font-medium text-gray-900"><%= block.Title %></h4>
                                                <p class="mt-2 text-base text-gray-500"><%= block.Description %></p>
                                            </div>
                                        </div>
                                    <% }); %>
                                <% } else { %>
                                    <div class="flex items-start">
                                        <div class="flex-shrink-0 h-12 w-12 rounded-md bg-primary text-white flex items-center justify-center">
                                            <span class="material-icons">verified_user</span>
                                        </div>
                                        <div class="ml-4">
                                            <h4 class="text-lg leading-6 font-medium text-gray-900">Validazioni Sicure</h4>
                                            <p class="mt-2 text-base text-gray-500">I processi di approvazione multi-livello garantiscono il rigoroso rispetto delle politiche di utilizzo dei veicoli.</p>
                                        </div>
                                    </div>
                                    <div class="flex items-start">
                                        <div class="flex-shrink-0 h-12 w-12 rounded-md bg-primary text-white flex items-center justify-center">
                                            <span class="material-icons">gps_fixed</span>
                                        </div>
                                        <div class="ml-4">
                                            <h4 class="text-lg leading-6 font-medium text-gray-900">Tracciamento GPS in Tempo Reale</h4>
                                            <p class="mt-2 text-base text-gray-500">Monitora la posizione dell'intera flotta in tempo reale sulla mappa. Ottimizza i percorsi e garantisce la sicurezza dei conducenti.</p>
                                        </div>
                                    </div>
                                <% } %>
                            </div>
                        </div>

                        <!-- Map Preview -->
                        <div class="relative">
                            <div
                                class="relative mx-auto w-full rounded-lg shadow-lg lg:max-w-md bg-white border border-gray-200 overflow-hidden card-hover">
                                <% var mf = (cf.MappaFlotta) || {}; %>
                                <div
                                    class="bg-gray-100 px-4 py-3 border-b border-gray-200 flex justify-between items-center">
                                    <span class="text-sm font-semibold text-gray-700"><%= mf.MappaTitle || 'Mappa Flotta' %></span>
                                    <span
                                        class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800"><%= mf.Tag || 'Live' %></span>
                                </div>
                                <div class="relative h-64 bg-gray-200">
                                    <img alt="Vista dettagliata mappa città"
                                        class="w-full h-full object-cover opacity-70"
                                        src="/images/fleet-tracking.png" />
                                    <div class="absolute top-1/4 left-1/4 transform -translate-x-1/2 -translate-y-1/2">
                                        <div class="relative">
                                            <div
                                                class="w-4 h-4 bg-primary rounded-full animate-ping absolute opacity-75">
                                            </div>
                                            <span
                                                class="material-icons text-primary text-3xl relative z-10 drop-shadow-md"><%= mf.Icon1 || 'place' %></span>
                                        </div>
                                    </div>
                                    <div
                                        class="absolute bottom-1/3 right-1/3 transform -translate-x-1/2 -translate-y-1/2">
                                        <span class="material-icons text-blue-500 text-3xl drop-shadow-md"><%= mf.Icon2 || 'place' %></span>
                                    </div>
                                    <div class="absolute top-1/2 right-1/4 transform -translate-x-1/2 -translate-y-1/2">
                                        <span
                                            class="material-icons text-yellow-500 text-3xl drop-shadow-md"><%= mf.Icon3 || 'place' %></span>
                                    </div>
                                </div>
                                <div class="p-4">
                                    <div class="flex items-center justify-between">
                                        <div class="flex items-center">
                                            <div
                                                class="h-8 w-8 rounded-full bg-gray-300 overflow-hidden mr-3 flex items-center justify-center">
                                                <span class="material-icons text-gray-600"><%= mf.PIcon || 'person' %></span>
                                            </div>
                                            <div>
                                                <p class="text-sm font-medium text-gray-900"><%= mf.Name || 'Luigi Di Mauro' %></p>
                                                <p class="text-xs text-gray-500"><%= mf.Car || 'Fiat Panda - EZ 998 KL' %></p>
                                            </div>
                                        </div>
                                        <span class="text-xs font-bold text-primary"><%= mf.Status || 'In Movimento' %></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Smart Access Section -->
                    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
                        <!-- Image First on Desktop -->
                        <div class="lg:order-1 order-2">
                            <div class="relative w-full max-w-sm mx-auto">
                                <div
                                    class="rounded-2xl bg-white shadow-xl overflow-hidden flex items-center justify-center p-8 border border-gray-100 card-hover">
                                    <% if (cf.AccesImage) { %>
                                        <img alt="<%= cf.AccesImage.alternativeText || 'Meccanismo di serratura intelligente ad alta tecnologia' %>"
                                            class="object-contain w-full h-full transform hover:scale-105 transition-transform duration-500"
                                            src="<%= strapiUrl + cf.AccesImage.url %>" />
                                    <% } else { %>
                                        <img alt="Meccanismo di serratura intelligente ad alta tecnologia"
                                            class="object-contain w-full h-full transform hover:scale-105 transition-transform duration-500"
                                            src="/images/smart-lock.png" />
                                    <% } %>
                                </div>
                                <div
                                    class="absolute -top-4 -right-4 w-24 h-24 bg-primary/10 rounded-full flex items-center justify-center animate-pulse">
                                    <span class="material-icons text-primary text-4xl"><%= (cf.Icon2 && cf.Icon2.trim()) || 'wifi_tethering' %></span>
                                </div>
                            </div>
                        </div>

                        <!-- Text Content -->
                        <div class="lg:order-2 order-1">
                            <h3 class="text-2xl font-extrabold text-gray-900 tracking-tight sm:text-3xl mb-4">
                                <%= cf.Title6 || 'Controllo Accesso Intelligente' %>
                            </h3>
                            <p class="text-lg text-gray-600 mb-8 leading-relaxed">
                                <% if (cf.SubTitle5) { %>
                                    <%= cf.SubTitle5 %>
                                <% } else { %>
                                    Dimentica le chiavi fisiche. La nostra tecnologia di geofencing consente capacità
                                    automatiche di blocco e sblocco quando il conducente è vicino al veicolo.
                                <% } %>
                            </p>

                            <ul class="space-y-4">
                                <% if (cf.AccesBlock && cf.AccesBlock.length > 0) { %>
                                    <% cf.AccesBlock.forEach(function(item) { %>
                                        <% var colonIdx = item.Text.indexOf(':'); %>
                                        <li class="flex items-start">
                                            <span class="material-icons text-primary mr-3 mt-1"><%= item.Icon || 'check_circle' %></span>
                                            <div>
                                                <p class="text-base text-gray-600">
                                                    <% if (colonIdx > -1) { %>
                                                        <strong class="font-medium text-gray-900"><%= item.Text.substring(0, colonIdx).trim() %>:</strong> <%= item.Text.substring(colonIdx + 1).trim() %>
                                                    <% } else { %>
                                                        <%= item.Text %>
                                                    <% } %>
                                                </p>
                                            </div>
                                        </li>
                                    <% }); %>
                                <% } else { %>
                                    <li class="flex items-start">
                                        <span class="material-icons text-primary mr-3 mt-1">check_circle</span>
                                        <div>
                                            <p class="text-base text-gray-600">
                                                <strong class="font-medium text-gray-900">Chiave Mobile:</strong> Sblocca le auto direttamente dall'app.
                                            </p>
                                        </div>
                                    </li>
                                    <li class="flex items-start">
                                        <span class="material-icons text-primary mr-3 mt-1">check_circle</span>
                                        <div>
                                            <p class="text-base text-gray-600">
                                                <strong class="font-medium text-gray-900">Geofencing:</strong> Rilevamento automatico di prossimità per accesso senza interruzioni.
                                            </p>
                                        </div>
                                    </li>
                                    <li class="flex items-start">
                                        <span class="material-icons text-primary mr-3 mt-1">check_circle</span>
                                        <div>
                                            <p class="text-base text-gray-600">
                                                <strong class="font-medium text-gray-900">Accesso Remoto:</strong> Gli amministratori possono sbloccare i veicoli da remoto in caso di emergenza.
                                            </p>
                                        </div>
                                    </li>
                                <% } %>
                            </ul>
                        </div>
                    </div>
                </div>
            </section>

            <!-- CTA Section -->
            <section class="bg-gray-900 py-16">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                    <h2 class="text-3xl font-extrabold text-white mb-4">
                        <% if (cf.Title7) { %>
                            <%= cf.Title7 %>
                        <% } else { %>
                            Pronto a ottimizzare la gestione della tua flotta?
                        <% } %>
                    </h2>
                    <p class="text-xl text-gray-400 mb-8 max-w-2xl mx-auto">
                        <% if (cf.Subtitle6) { %>
                            <%= cf.Subtitle6 %>
                        <% } else { %>
                            Unisciti alle aziende che già usano CarFleet per semplificare la logistica e ridurre i
                            costi operativi.
                        <% } %>
                    </p>
                    <div class="flex justify-center">
                        <button onclick="openDemoModal('CarFleet')"
                            class="px-8 py-3 bg-primary text-white font-bold rounded-lg hover:bg-green-600 transition shadow-lg shadow-green-500/30">
                            <%= cf.Button3 || 'Contatta le Vendite' %>
                        </button>
                    </div>
                </div>
            </section>
        </main>

        <%- include('partials/demo-modal') %>
            <%- include('partials/footer') %>
</body>

</html>