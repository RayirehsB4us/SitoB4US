<%
  const footerData = typeof footer !== 'undefined' ? footer : null;
  const columns = footerData && Array.isArray(footerData.columns) ? footerData.columns : [];
  const hasFooter = !!footerData;
  const isInternal = function (href) {
    return typeof href === 'string' && href.startsWith('/');
  };
  // Logo + tutte le colonne devono stare sulla stessa riga (layout desktop)
  const totalCols = 1 + columns.length; // 1 colonna per il logo + n colonne da Strapi
  let gridColsClass = 'lg:grid-cols-4';
  if (totalCols <= 2) gridColsClass = 'lg:grid-cols-2';
  else if (totalCols === 3) gridColsClass = 'lg:grid-cols-3';
  else if (totalCols === 4) gridColsClass = 'lg:grid-cols-4';
  else if (totalCols === 5) gridColsClass = 'lg:grid-cols-5';
%>

<% if (hasFooter) { %>
<footer class="bg-white border-t border-gray-100 pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid gap-12 mb-12 <%= gridColsClass %>">
      <div class="lg:col-span-1">
        <% if (footerData.logoUrl) { %>
          <img alt="<%= footerData.logoName || 'B4US Logo' %>" class="h-10 w-auto mb-6" src="<%= footerData.logoUrl %>" />
        <% } %>
        <% if (footerData.descrizione) { %>
          <p class="text-sm text-gray-500">
            <%= footerData.descrizione %>
          </p>
        <% } %>
      </div>

      <% columns.forEach(function(col) { %>
        <div>
          <% if (col.Title) { %>
            <h4 class="font-bold text-gray-900 mb-6"><%- sanitize(col.Title) %></h4>
          <% } %>
          <ul class="space-y-4 text-sm text-gray-600">
            <% (col.link || []).forEach(function(item) { %>
              <%
                const href = item.link;
                const title = item.Title;
                const icon = item.icon;
              %>
              <li class="<%= icon ? 'flex items-start space-x-3' : '' %>">
                <% if (icon) { %>
                  <span class="material-symbols-outlined text-primary text-xl"><%= icon %></span>
                <% } %>
                <% if (href && title) { %>
                  <% if (isInternal(href)) { %>
                    <a class="hover:text-primary transition-colors" href="<%= href %>"><%- sanitize(title) %></a>
                  <% } else { %>
                    <a class="hover:text-primary transition-colors" href="<%= href %>" target="_blank" rel="noopener noreferrer"><%- sanitize(title) %></a>
                  <% } %>
                <% } else if (title) { %>
                  <span><%- sanitize(title) %></span>
                <% } %>
              </li>
            <% }); %>
          </ul>
        </div>
      <% }); %>
    </div>

    <% if (footerData.subTitle) { %>
      <div class="pt-8 border-t border-gray-100 flex items-center justify-center">
        <p class="text-xs text-gray-400 text-center">
          <%- sanitize(footerData.subTitle) %>
        </p>
      </div>
    <% } %>
  </div>
</footer>
<% } %>