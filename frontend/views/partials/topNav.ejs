<nav class="fixed top-0 left-0 right-0 z-50 glass-nav border-b border-slate-200 bg-white/80 backdrop-blur-md">
    <div class="nav-container">
        <div class="flex-shrink-0 flex items-center">
            <a href="/home">
                <img alt="B4US Logo" class="nav-logo" src="/images/logo.png" />
            </a>
        </div>
        
        <!-- Desktop Menu -->
        <div class="hidden lg:flex items-center space-x-8">
            <%
                const menuItems = Array.isArray(topMenu) ? topMenu : [];
                const isVisible = function (value) {
                    return value === true || value === 'true' || value === 1 || value === '1';
                };
            %>

            <% menuItems.forEach(function(item) { 
                if (!item || !isVisible(item.visible)) return;
                const hasSubmenu = Array.isArray(item.sottoMenu) && item.sottoMenu.length > 0;
            %>
                <% if (hasSubmenu) { %>
                    <!-- Desktop Dropdown -->
                    <div class="nav-dropdown relative">
                        <a class="text-sm font-semibold hover:text-primary transition-colors inline-flex items-center gap-1 cursor-pointer" href="<%= item.path %>">
                            <%= item.label %>
                            <svg class="w-3.5 h-3.5 nav-dropdown-arrow transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                            </svg>
                        </a>
                        <div class="nav-dropdown-menu absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible transition-all duration-200">
                            <div class="bg-white rounded-xl shadow-lg border border-slate-200 py-2 min-w-[180px]">
                                <% item.sottoMenu.forEach(function(sub) { 
                                    if (!sub || !isVisible(sub.visible)) return;
                                %>
                                    <a class="block px-4 py-2 text-sm font-medium text-gray-700 hover:text-primary hover:bg-gray-50 transition-colors" href="<%= sub.path %>">
                                        <%= sub.label %>
                                    </a>
                                <% }); %>
                            </div>
                        </div>
                    </div>
                <% } else { %>
                    <!-- Desktop Simple Link -->
                    <a class="text-sm font-semibold hover:text-primary transition-colors" href="<%= item.path %>">
                        <%= item.label %>
                    </a>
                <% } %>
            <% }); %>

            <% if (typeof showLoginButton !== 'undefined' && showLoginButton) { %>
            <a class="inline-flex items-center justify-center px-5 py-2 text-sm font-bold text-white bg-primary rounded-full hover:bg-green-600 transition-all shadow-lg shadow-primary/20"
                href="/login">Accedi</a>
            <% } %>
        </div>
        
        <!-- Mobile Menu Button -->
        <button id="mobile-menu-button" class="lg:hidden flex items-center justify-center p-2 rounded-md text-gray-700 hover:text-primary hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-primary transition-colors" 
                aria-label="Menu" 
                aria-expanded="false"
                style="min-width: 40px; min-height: 40px;">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
        </button>
    </div>
    
    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-slate-200 shadow-lg absolute left-0 right-0" style="top: var(--nav-height);">
        <div class="px-4 py-3 space-y-1 max-h-[calc(100vh-var(--nav-height))] overflow-y-auto">
            <% menuItems.forEach(function(item) { 
                if (!item || !isVisible(item.visible)) return;
                const hasSubmenu = Array.isArray(item.sottoMenu) && item.sottoMenu.length > 0;
            %>
                <% if (hasSubmenu) { %>
                    <!-- Mobile with sotto-menu -->
                    <div class="mobile-submenu-group">
                        <button class="mobile-submenu-toggle flex items-center justify-between w-full px-3 py-2 text-base font-semibold text-gray-700 hover:text-primary hover:bg-gray-50 rounded-lg transition-colors" aria-expanded="false">
                            <a href="<%= item.path %>" class="text-inherit hover:text-primary" onclick="event.stopPropagation();"><%= item.label %></a>
                            <svg class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                            </svg>
                        </button>
                        <div class="mobile-submenu hidden pl-4 space-y-1 mt-1">
                            <% item.sottoMenu.forEach(function(sub) { 
                                if (!sub || !isVisible(sub.visible)) return;
                            %>
                                <a class="block px-3 py-2 text-sm font-medium text-gray-600 hover:text-primary hover:bg-gray-50 rounded-lg transition-colors" href="<%= sub.path %>">
                                    <%= sub.label %>
                                </a>
                            <% }); %>
                        </div>
                    </div>
                <% } else { %>
                    <!-- Mobile simple link -->
                    <a class="block px-3 py-2 text-base font-semibold text-gray-700 hover:text-primary hover:bg-gray-50 rounded-lg transition-colors" href="<%= item.path %>">
                        <%= item.label %>
                    </a>
                <% } %>
            <% }); %>

            <% if (typeof showLoginButton !== 'undefined' && showLoginButton) { %>
            <a class="block mx-3 my-2 px-5 py-2 text-center text-sm font-bold text-white bg-primary rounded-full hover:bg-green-600 transition-all shadow-lg shadow-primary/20" href="/login">Accedi</a>
            <% } %>
        </div>
    </div>
</nav>

<script>
    // Mobile menu toggle and submenu behavior
    document.addEventListener('DOMContentLoaded', function() {
        const menuButton = document.getElementById('mobile-menu-button');
        const mobileMenu = document.getElementById('mobile-menu');
        
        if (menuButton && mobileMenu) {
            menuButton.addEventListener('click', function(e) {
                e.stopPropagation();
                const isOpen = !mobileMenu.classList.contains('hidden');
                mobileMenu.classList.toggle('hidden');
                menuButton.setAttribute('aria-expanded', !isOpen);
            });
            
            // Close menu when clicking outside
            document.addEventListener('click', function(event) {
                const isClickInside = menuButton.contains(event.target) || mobileMenu.contains(event.target);
                if (!isClickInside && !mobileMenu.classList.contains('hidden')) {
                    mobileMenu.classList.add('hidden');
                    menuButton.setAttribute('aria-expanded', 'false');
                }
            });
            
            // Close menu when clicking on a link (exclude submenu toggles)
            const menuLinks = mobileMenu.querySelectorAll('a:not(.mobile-submenu-group a.text-inherit)');
            menuLinks.forEach(link => {
                link.addEventListener('click', function() {
                    mobileMenu.classList.add('hidden');
                    menuButton.setAttribute('aria-expanded', 'false');
                });
            });

            // Mobile submenu toggle
            const submenuToggles = mobileMenu.querySelectorAll('.mobile-submenu-toggle');
            submenuToggles.forEach(toggle => {
                toggle.addEventListener('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    const submenu = this.nextElementSibling;
                    const arrow = this.querySelector('svg');
                    const isOpen = !submenu.classList.contains('hidden');
                    submenu.classList.toggle('hidden');
                    this.setAttribute('aria-expanded', !isOpen);
                    if (arrow) {
                        arrow.style.transform = isOpen ? '' : 'rotate(180deg)';
                    }
                });
            });
        } else {
            console.error('Menu button or mobile menu not found');
        }
    });
</script>

