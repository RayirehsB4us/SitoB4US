<!DOCTYPE html>
<html class="scroll-smooth" lang="it">

<head>
    <%- include('partials/head') %>
</head>

<body class="bg-background-light text-slate-800 font-sans transition-colors duration-300">
    <%- include('partials/topNav') %>
    <%- include('partials/skeleton-page') %>

        <main id="page-content" class="hidden opacity-0 transition-opacity duration-300">
        <!-- Hero Section -->
        <section class="relative py-20 overflow-hidden">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="lg:grid lg:grid-cols-2 lg:gap-12 items-center">
                    <div>
                        <span
                            class="inline-block py-1 px-3 rounded-full bg-green-100 dark:bg-green-900/30 text-primary text-xs font-bold uppercase tracking-wider mb-6">
                            <%- (chiSiamoData && chiSiamoData.HeroTag) || '' %>
                        </span>
                        <h1
                            class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-slate-900 dark:text-white leading-tight mb-6">
                            <%- (chiSiamoData && chiSiamoData.HeroTitle) || '' %>
                        </h1>
                        <p class="text-lg text-slate-600 dark:text-slate-400 mb-8 leading-relaxed">
                            <%= (chiSiamoData && chiSiamoData.HeroDescription) || '' %>
                        </p>
                    </div>
                    <div class="mt-12 lg:mt-0 relative">
                        <div class="aspect-video rounded-3xl overflow-hidden shadow-2xl">
                            <% if (chiSiamoData && chiSiamoData.HeroImage) { %>
                                <img alt="Team B4US"
                                    class="w-full h-full object-cover"
                                    src="<%= strapiUrl %><%= chiSiamoData.HeroImage.url %>" />
                            <% } else { %>
                                <img alt="Team working together in a modern office"
                                    class="w-full h-full object-cover"
                                    src="images/2026.jpg" />
                            <% } %>
                        </div>
                        <div class="absolute -bottom-6 -left-6 w-32 h-32 bg-primary/10 rounded-full blur-3xl"></div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Values Section -->
        <section class="py-20 bg-slate-50 dark:bg-slate-900/50">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center max-w-3xl mx-auto mb-16">
                    <h2 class="text-3xl font-bold mb-4"><%- (chiSiamoData && chiSiamoData.ValuesTitle) || '' %></h2>
                    <p class="text-slate-600 dark:text-slate-400"><%= (chiSiamoData && chiSiamoData.ValuesSubTitle) || '' %></p>
                </div>
                <div class="grid md:grid-cols-3 gap-8">
                    <% if (chiSiamoData && chiSiamoData.ValueCards && chiSiamoData.ValueCards.length > 0) { %>
                        <% chiSiamoData.ValueCards.forEach(function(card) { %>
                            <div
                                class="p-8 bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 hover:shadow-md transition-shadow">
                                <div
                                    class="w-12 h-12 bg-green-100 dark:bg-green-900/30 text-primary rounded-xl flex items-center justify-center mb-6">
                                    <span class="material-symbols-outlined"><%= card.icon || '' %></span>
                                </div>
                                <h3 class="text-xl font-bold mb-3"><%- card.title %></h3>
                                <p class="text-slate-600 dark:text-slate-400"><%= card.description %></p>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <!-- Fallback statico -->
                        <div
                            class="p-8 bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 hover:shadow-md transition-shadow">
                            <div
                                class="w-12 h-12 bg-green-100 dark:bg-green-900/30 text-primary rounded-xl flex items-center justify-center mb-6">
                                <span class="material-symbols-outlined">psychology</span>
                            </div>
                            <h3 class="text-xl font-bold mb-3">Visione Strategica</h3>
                            <p class="text-slate-600 dark:text-slate-400">Anticipiamo i cambiamenti del mercato IT per
                                offrire soluzioni che durano nel tempo.</p>
                        </div>
                        <div
                            class="p-8 bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 hover:shadow-md transition-shadow">
                            <div
                                class="w-12 h-12 bg-green-100 dark:bg-green-900/30 text-primary rounded-xl flex items-center justify-center mb-6">
                                <span class="material-symbols-outlined">groups</span>
                            </div>
                            <h3 class="text-xl font-bold mb-3">Persone al Centro</h3>
                            <p class="text-slate-600 dark:text-slate-400">Il nostro capitale più grande è il team di esperti
                                che lavora con passione ogni giorno.</p>
                        </div>
                        <div
                            class="p-8 bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 hover:shadow-md transition-shadow">
                            <div
                                class="w-12 h-12 bg-green-100 dark:bg-green-900/30 text-primary rounded-xl flex items-center justify-center mb-6">
                                <span class="material-symbols-outlined">bolt</span>
                            </div>
                            <h3 class="text-xl font-bold mb-3">Agilità e Risultati</h3>
                            <p class="text-slate-600 dark:text-slate-400">Rispondiamo velocemente alle sfide complesse con
                                soluzioni pragmatiche ed efficaci.</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </section>

        <!-- Team Section -->
        <section class="py-24">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="mb-8 flex flex-col md:flex-row md:items-end md:justify-between gap-4">
                    <h2 class="text-3xl font-bold">
                        <%- (chiSiamoData && chiSiamoData.TeamTitle) || '' %>
                    </h2>
                    <%
                      const teamCta = chiSiamoData && chiSiamoData.Team ? chiSiamoData.Team : {};
                      const teamLabel = teamCta.Label || '';
                      const teamIcon = teamCta.icon || '';
                    %>
                    <a href="/team"
                        class="inline-flex items-center gap-2 self-start px-5 py-2 rounded-full text-sm font-bold bg-primary text-white shadow-sm hover:bg-green-600 hover:shadow-green-500/30 transition-all">
                        <span class="material-symbols-outlined text-base"><%= teamIcon %></span>
                        <%= teamLabel %>
                    </a>
                </div>
                <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
                    <% if (teamMembers && teamMembers.length> 0) { %>
                        <% teamMembers.forEach(function(member) { %>
                            <div class="group">
                                <div
                                    class="relative overflow-hidden rounded-2xl mb-4 aspect-[4/5] bg-slate-100 dark:bg-slate-800">
                                    <% if (member.foto) { %>
                                        <img alt="<%= member.nome %> - <%= member.ruolo %>"
                                            class="w-full h-full object-cover object-center group-hover:scale-110 transition-transform duration-500"
                                            src="<%= strapiUrl %><%= member.foto.url %>" />
                                        <% } else { %>
                                            <div
                                                class="w-full h-full flex items-center justify-center bg-gradient-to-br from-primary to-green-600">
                                                <span class="text-white text-6xl font-bold">
                                                    <%= member.nome.charAt(0) %>
                                                </span>
                                            </div>
                                            <% } %>
                                </div>
                                <h4 class="text-xl font-bold">
                                    <%= member.nome %>
                                </h4>
                                <p class="text-primary font-medium text-sm">
                                    <%= member.ruolo %>
                                </p>
                            </div>
                            <% }); %>
                                <% } else { %>
                                    <!-- Fallback: Nessun team member -->
                                    <div class="col-span-4 text-center py-12">
                                        <p class="text-slate-500">Nessun membro del team disponibile.</p>
                                    </div>
                                    <% } %>
                </div>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="py-20">
            <div class="max-w-4xl mx-auto px-4 text-center">
                <h2 class="text-3xl md:text-4xl font-bold mb-6 text-slate-900 dark:text-white"><%- (chiSiamoData && chiSiamoData.CtaTitle) || '' %></h2>
                <p class="text-slate-600 dark:text-slate-400 mb-10 text-lg"><%= (chiSiamoData && chiSiamoData.CtaDescription) || '' %></p>
                <a class="inline-flex items-center gap-2 bg-primary hover:bg-green-600 text-white font-bold py-4 px-10 rounded-full text-lg shadow-lg hover:shadow-green-500/30 transition-all transform hover:-translate-y-1"
                    href="/contatti">
                    <%= (chiSiamoData && chiSiamoData.CtaButtonText) || '' %>
                    <span class="material-symbols-outlined">arrow_forward</span>
                </a>
            </div>
        </section>
        </main>

        <%- include('partials/footer') %>

        <script>
            (function(){var s=document.getElementById('page-skeleton');var c=document.getElementById('page-content');function show(){if(s)s.classList.add('hidden');if(c){c.classList.remove('hidden');c.classList.remove('opacity-0');}}if(document.readyState==='complete')show();else window.addEventListener('load',show);})();
        </script>
</body>

</html>
