<!DOCTYPE html>
<html class="scroll-smooth" lang="it">

<head>
    <%- include('partials/head') %>
        <style>
            .hero-pattern {
                background-image: radial-gradient(circle at 2px 2px, rgba(40, 167, 69, 0.1) 1px, transparent 0);
                background-size: 40px 40px;
            }
        </style>
</head>

<body class="bg-background-light text-secondary font-sans transition-colors duration-300">
    <%- include('partials/topNav') %>

        <!-- Skeleton state -->
        <main id="home-skeleton" class="block">
            <section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden hero-pattern">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                    <div class="grid lg:grid-cols-2 gap-12 items-center">
                        <div class="space-y-6">
                            <div class="inline-flex px-16 py-3 rounded-full skeleton"></div>
                            <div class="space-y-3">
                                <div class="h-10 w-3/4 rounded-lg skeleton"></div>
                                <div class="h-10 w-1/2 rounded-lg skeleton"></div>
                            </div>
                            <div class="space-y-3 mt-4">
                                <div class="h-4 w-full rounded skeleton"></div>
                                <div class="h-4 w-5/6 rounded skeleton"></div>
                                <div class="h-4 w-2/3 rounded skeleton"></div>
                            </div>
                            <!-- Keep buttons only in the real content to avoid shape changes -->
                        </div>
                        <div class="relative">
                            <div class="w-full h-80 md:h-96 rounded-2xl skeleton"></div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="py-24 bg-white" id="intro-skeleton">
                <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center space-y-8">
                    <div class="h-9 w-1/2 mx-auto rounded-lg skeleton"></div>
                    <div class="space-y-4">
                        <div class="h-4 w-full rounded skeleton"></div>
                        <div class="h-4 w-5/6 mx-auto rounded skeleton"></div>
                        <div class="h-4 w-2/3 mx-auto rounded skeleton"></div>
                    </div>
                </div>
            </section>

            <section class="py-24 bg-primary relative overflow-hidden">
                <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
                    <div class="bg-white/10 backdrop-blur-md rounded-3xl p-10 md:p-16 border border-white/20 shadow-2xl space-y-6">
                        <div class="h-10 w-24 rounded skeleton"></div>
                        <div class="space-y-4">
                            <div class="h-4 w-full rounded skeleton"></div>
                            <div class="h-4 w-11/12 rounded skeleton"></div>
                            <div class="h-4 w-4/5 rounded skeleton"></div>
                        </div>
                        <div class="flex items-center gap-4 mt-6">
                            <div class="h-1 w-20 bg-white/40 rounded-full"></div>
                            <div class="h-6 w-32 rounded skeleton"></div>
                        </div>
                    </div>
                </div>
            </section>
        </main>

        <!-- Real content -->
        <main id="home-content" class="hidden opacity-0 transition-opacity duration-300">
        <section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden hero-pattern">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="grid lg:grid-cols-2 gap-12 items-center">
                    <div class="relative z-10">
                        <span
                            class="inline-block px-4 py-1.5 mb-6 text-xs font-bold tracking-widest text-primary uppercase bg-green-100 rounded-full">
                            Innovazione &amp; Consulenza IT
                        </span>
                        <h1 class="text-5xl lg:text-7xl font-display font-bold text-gray-900 leading-tight mb-6">
                            <%- home.heroTitle || 'Simplify IT' %> <br /><span class="text-primary italic">with
                                    B4US.</span>
                        </h1>
                        <p class="text-lg lg:text-xl text-gray-600 mb-10 max-w-lg leading-relaxed">
                            <%- home.heroSubtitle
                                || 'Siamo una giovane e dinamica società di consulenza, soluzioni e servizi IT nata per guidare la tua azienda nel futuro digitale.'
                                %>
                        </p>
                        <div class="flex flex-col sm:flex-row space-y-4 sm:space-y-0 sm:space-x-4">
                            <a class="inline-flex items-center justify-center px-8 py-4 text-base font-bold text-white bg-primary rounded-xl hover:bg-green-600 transition-all shadow-xl shadow-primary/30 group"
                                href="#intro">
                                Scopri di più
                                <span
                                    class="material-symbols-outlined ml-2 group-hover:translate-x-1 transition-transform">arrow_forward</span>
                            </a>
                            <a class="inline-flex items-center justify-center px-8 py-4 text-base font-bold text-secondary bg-white border border-gray-200 rounded-xl hover:bg-gray-50 transition-all"
                                href="/servizi">
                                I nostri servizi
                            </a>
                        </div>
                    </div>
                    <div class="relative">
                        <div class="absolute -top-10 -right-10 w-64 h-64 bg-primary/10 rounded-full blur-3xl"></div>
                        <div class="absolute -bottom-10 -left-10 w-64 h-64 bg-green-400/10 rounded-full blur-3xl"></div>
                        <div class="relative overflow-hidden rounded-2xl shadow-2xl">
                            <img alt="Team collaborating on IT solutions"
                                class="w-full h-auto object-cover transform hover:scale-105 transition-transform duration-700"
                                src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=1200&q=80&fm=jpg&fit=crop" />
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="py-24 bg-white" id="intro">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                <h2 class="text-3xl font-display font-bold text-gray-900 mb-6">
                    <%- home.introTitle || 'Chi è B4US?' %>
                </h2>
                <div class="space-y-4 text-gray-600 leading-relaxed">
                    <% if (home.introDescription) { %>
                        <%- home.introDescription %>
                    <% } else { %>
                        <p>B4US è una giovane e dinamica società di consulenza, soluzioni e servizi
                            IT nata dalla passione di esperti del settore.</p>
                        <p>Ci impegniamo ogni giorno per semplificare la complessità tecnologica,
                            offrendo soluzioni su misura che permettano ai nostri clienti di
                            concentrarsi sul loro core business.</p>
                        <p>La nostra missione è essere il partner tecnologico di fiducia, guidando
                            l'innovazione attraverso competenza, etica e visione.</p>
                    <% } %>
                </div>
            </div>
        </section>

        <section class="py-24 bg-primary relative overflow-hidden">
            <div class="absolute inset-0 opacity-10">
                <div
                    class="absolute top-0 left-0 w-96 h-96 border-8 border-white rounded-full -translate-x-1/2 -translate-y-1/2">
                </div>
                <div class="absolute bottom-0 right-0 w-64 h-64 bg-white rounded-full translate-x-1/3 translate-y-1/3">
                </div>
            </div>
            <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
                <div class="bg-white/10 backdrop-blur-md rounded-3xl p-10 md:p-16 border border-white/20 shadow-2xl">
                    <span class="material-symbols-outlined text-6xl text-white/40 mb-8 block">format_quote</span>
                    <blockquote
                        class="font-serif italic text-2xl md:text-3xl lg:text-4xl text-white leading-snug space-y-4">
                        <% if (home.einsteinQuote) { %>
                            <%- home.einsteinQuote %>
                        <% } else { %>
                            <p class="mb-4">"Non pretendiamo che le cose cambino, se continuiamo a fare le stesse cose. La
                                crisi può essere una grande benedizione per le persone e le nazioni, perché la crisi porta
                                progressi."</p>
                        <% } %>
                        
                    </blockquote>
                    <div class="mt-10 flex items-center gap-4">
                        <div class="h-1 w-20 bg-white"></div>
                        <cite class="not-italic text-xl font-bold text-white uppercase tracking-widest">Albert
                            Einstein</cite>
                    </div>
                </div>
            </div>
        </section>

        </main>

        <%- include('partials/footer') %>

        <script>
            // Skeleton loading: keep skeleton until page (fonts, icons, images) is loaded
            (function () {
                var skeleton = document.getElementById('home-skeleton');
                var content = document.getElementById('home-content');

                function showContent() {
                    if (!skeleton || !content) return;
                    skeleton.classList.add('hidden');
                    content.classList.remove('hidden');
                    content.classList.remove('opacity-0');
                }

                if (document.readyState === 'complete') {
                    showContent();
                } else {
                    // Use window load so fonts/icons/images are ready, avoiding layout jumps
                    window.addEventListener('load', showContent);
                }
            })();
        </script>
</body>

</html>