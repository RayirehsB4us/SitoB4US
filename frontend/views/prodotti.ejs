<!DOCTYPE html>
<html class="scroll-smooth" lang="it">

<head>
    <%- include('partials/head') %>
        <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
        <style>
            @keyframes float {

                0%,
                100% {
                    transform: translateY(0px);
                }

                50% {
                    transform: translateY(-20px);
                }
            }

            .float-animation {
                animation: float 6s ease-in-out infinite;
            }

            .gradient-primary {
                background: linear-gradient(135deg, #2eab6f 0%, #248c5a 100%);
            }

            .gradient-purple {
                background: linear-gradient(135deg, #9333ea 0%, #7e22ce 100%);
            }

            .card-hover {
                transition: all 0.3s ease;
            }

            .card-hover:hover {
                transform: translateY(-5px);
                box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);
            }
        </style>
</head>

<body class="bg-background-light text-secondary font-sans transition-colors duration-300">
    <%- include('partials/navbar') %>

        <main class="pt-16">
            <!-- Hero Section -->
            <div class="relative overflow-hidden bg-gradient-to-br from-gray-50 to-white py-20">
                <div class="absolute top-0 right-0 -mr-20 -mt-20 w-96 h-96 rounded-full bg-primary/10 blur-3xl"></div>
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
                    <h1 class="text-4xl tracking-tight font-extrabold text-gray-900 sm:text-5xl md:text-6xl">
                        <span class="block">Semplifica le tue Operazioni</span>
                        <span class="block text-primary">con Software Intelligenti</span>
                    </h1>
                    <p class="mt-3 max-w-md mx-auto text-base text-gray-500 sm:text-lg md:mt-5 md:text-xl md:max-w-3xl">
                        Dalla gestione della flotta aziendale al controllo accessi smart per spazi condivisi.
                        Scopri come B4US trasforma logistiche complesse in flussi di lavoro semplici e digitali.
                    </p>
                </div>
            </div>

            <!-- Products Section -->
            <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-24">

                <!-- CarFleet Product -->
                <div class="lg:grid lg:grid-cols-12 lg:gap-16 items-center">
                    <div class="lg:col-span-5 order-2 lg:order-1 mt-10 lg:mt-0">
                        <div class="flex items-center gap-3 mb-4">
                            <div class="p-2 bg-primary/10 rounded-lg">
                                <span class="material-icons text-primary text-3xl">directions_car</span>
                            </div>
                            <h2 class="text-3xl font-bold text-gray-900">CarFleet</h2>
                        </div>
                        <h3 class="text-xl font-medium text-gray-500 mb-6">Gestione Flotta Aziendale con PowerApps</h3>
                        <p class="text-lg text-gray-600 mb-8 leading-relaxed">
                            Ottimizza l'allocazione dei tuoi veicoli con tracciamento in tempo reale, approvazioni delle
                            prenotazioni
                            e programmazione della manutenzione. Costruito sulla robusta Microsoft Power Platform per
                            un'integrazione perfetta.
                        </p>
                        <ul class="space-y-4 mb-8">
                            <li class="flex items-start">
                                <span class="material-icons text-primary mr-3 mt-1">check_circle</span>
                                <div>
                                    <span class="font-semibold text-gray-900">Dashboard Intelligente</span>
                                    <p class="text-sm text-gray-500">Metriche visive per viaggi attivi, ritardi e
                                        validazioni.</p>
                                </div>
                            </li>
                            <li class="flex items-start">
                                <span class="material-icons text-primary mr-3 mt-1">check_circle</span>
                                <div>
                                    <span class="font-semibold text-gray-900">Geofence & GPS</span>
                                    <p class="text-sm text-gray-500">Tracciamento della posizione in tempo reale e
                                        avvisi di confine.</p>
                                </div>
                            </li>
                            <li class="flex items-start">
                                <span class="material-icons text-primary mr-3 mt-1">check_circle</span>
                                <div>
                                    <span class="font-semibold text-gray-900">Flusso di Manutenzione</span>
                                    <p class="text-sm text-gray-500">Avvisi automatici per assistenza e riparazioni.</p>
                                </div>
                            </li>
                        </ul>
                        <a href="/carfleet"
                            class="text-primary hover:text-primary-dark font-semibold inline-flex items-center group transition-colors">
                            Esplora le Funzionalità di CarFleet
                            <span
                                class="material-icons ml-2 group-hover:translate-x-1 transition-transform text-sm">arrow_forward</span>
                        </a>
                    </div>

                    <div class="lg:col-span-7 order-1 lg:order-2">
                        <div
                            class="relative rounded-xl shadow-2xl overflow-hidden transform hover:scale-[1.02] transition-transform duration-500 card-hover">
                            <img src="/images/carfleet-dashboard.png"
                                alt="Dashboard CarFleet - Gestione Flotta Aziendale" class="w-full h-auto object-cover">
                        </div>
                    </div>
                </div>

                <!-- Divider -->
                <div class="relative">
                    <div aria-hidden="true" class="absolute inset-0 flex items-center">
                        <div class="w-full border-t border-gray-200"></div>
                    </div>
                </div>

                <!-- Open4US Product -->
                <div class="lg:grid lg:grid-cols-12 lg:gap-16 items-center">
                    <div class="lg:col-span-6">
                        <div class="relative">
                            <div
                                class="rounded-xl shadow-2xl bg-white border border-gray-200 overflow-hidden relative z-10 p-6 card-hover">
                                <div class="border-b border-gray-100 pb-4 mb-4 flex justify-between items-center">
                                    <span class="text-lg font-bold text-gray-800">Dashboard Prenotazioni</span>
                                    <div class="bg-green-100 text-green-800 text-xs px-2 py-1 rounded">Confermato</div>
                                </div>
                                <div class="space-y-3">
                                    <div class="bg-gray-50 p-3 rounded border-l-4 border-primary">
                                        <div class="text-sm font-semibold">Ufficio Amministrativo Comune Gorgonzola
                                        </div>
                                        <div class="text-xs text-gray-500 mt-1">26/02/2025 17:00 - 17:30</div>
                                        <div class="flex items-center gap-2 mt-2">
                                            <span class="material-icons text-gray-400 text-sm">lock</span>
                                            <span class="text-xs text-gray-500">Serratura Smart ISEO Pronta</span>
                                        </div>
                                    </div>
                                    <div class="bg-gray-50 p-3 rounded border-l-4 border-purple-500">
                                        <div class="text-sm font-semibold">Prenotazione Campo da Basket</div>
                                        <div class="text-xs text-gray-500 mt-1">Mercoledì 28/05/2025</div>
                                        <div class="flex items-center gap-2 mt-2">
                                            <span class="material-icons text-gray-400 text-sm">smartphone</span>
                                            <span class="text-xs text-gray-500">Sblocco App Abilitato</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div
                                class="absolute -right-12 -bottom-10 z-20 w-48 h-48 lg:w-64 lg:h-64 filter drop-shadow-2xl float-animation">
                                <div
                                    class="relative w-full h-full bg-white rounded-full flex items-center justify-center border-4 border-white overflow-hidden shadow-2xl">
                                    <img src="/images/smart-lock.png" alt="Serratura Smart ISEO per Controllo Accessi"
                                        class="w-full h-full object-cover">
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="lg:col-span-6 mt-16 lg:mt-0">
                        <div class="flex items-center gap-3 mb-4">
                            <div class="p-2 bg-purple-100 rounded-lg">
                                <span class="material-icons text-purple-600 text-3xl">meeting_room</span>
                            </div>
                            <h2 class="text-3xl font-bold text-gray-900">Open4US</h2>
                        </div>
                        <h3 class="text-xl font-medium text-gray-500 mb-6">Accesso Smart per Spazi Condivisi</h3>
                        <p class="text-lg text-gray-600 mb-8 leading-relaxed">
                            Rivoluziona il modo in cui gestisci coworking, palestre e strutture pubbliche.
                            Integrazione perfetta con serrature smart ISEO e il sistema di gestione Luckey per
                            un'esperienza senza chiavi.
                        </p>
                        <div class="grid sm:grid-cols-2 gap-6 mb-8">
                            <div class="bg-white p-4 rounded-lg border border-gray-100 shadow-sm card-hover">
                                <span class="material-icons text-primary mb-2">bluetooth</span>
                                <h4 class="font-bold text-gray-900">Sblocco Bluetooth</h4>
                                <p class="text-sm text-gray-500 mt-1">Sblocca le porte direttamente dall'app del tuo
                                    smartphone in modo sicuro.</p>
                            </div>
                            <div class="bg-white p-4 rounded-lg border border-gray-100 shadow-sm card-hover">
                                <span class="material-icons text-primary mb-2">dashboard</span>
                                <h4 class="font-bold text-gray-900">Dashboard Centrale</h4>
                                <p class="text-sm text-gray-500 mt-1">Gestisci i permessi utente e visualizza i log di
                                    accesso in tempo reale.</p>
                            </div>
                            <div class="bg-white p-4 rounded-lg border border-gray-100 shadow-sm card-hover">
                                <span class="material-icons text-primary mb-2">event_available</span>
                                <h4 class="font-bold text-gray-900">Sistema di Prenotazione</h4>
                                <p class="text-sm text-gray-500 mt-1">Calendario integrato per la prenotazione di sale e
                                    risorse.</p>
                            </div>
                            <div class="bg-white p-4 rounded-lg border border-gray-100 shadow-sm card-hover">
                                <span class="material-icons text-primary mb-2">settings_remote</span>
                                <h4 class="font-bold text-gray-900">Integrazione Hardware</h4>
                                <p class="text-sm text-gray-500 mt-1">Funziona nativamente con gli ecosistemi ISEO Argo
                                    e Luckey.</p>
                            </div>
                        </div>
                        <a href="/open4us"
                            class="text-purple-600 hover:text-purple-700 font-semibold inline-flex items-center group transition-colors">
                            Scopri di più sull'Accesso Smart
                            <span
                                class="material-icons ml-2 group-hover:translate-x-1 transition-transform text-sm">arrow_forward</span>
                        </a>
                    </div>
                </div>

            </section>
        </main>

        <%- include('partials/footer') %>
</body>

</html>