<!DOCTYPE html>
<html class="scroll-smooth" lang="it">

<head>
    <%- include('partials/head') %>
        <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
        <style>
            @keyframes float {

                0%,
                100% {
                    transform: translateY(0px);
                }

                50% {
                    transform: translateY(-20px);
                }
            }

            .float-animation {
                animation: float 6s ease-in-out infinite;
            }

            .gradient-primary {
                background: linear-gradient(135deg, #2eab6f 0%, #248c5a 100%);
            }

            .gradient-purple {
                background: linear-gradient(135deg, #9333ea 0%, #7e22ce 100%);
            }

            .card-hover {
                transition: all 0.3s ease;
            }

            .card-hover:hover {
                transform: translateY(-5px);
                box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);
            }
        </style>
</head>

<body class="bg-background-light text-secondary font-sans transition-colors duration-300">
<%- include('partials/topNav') %>
    <%- include('partials/skeleton-page') %>

        <main id="page-content" class="pt-16 hidden opacity-0 transition-opacity duration-300">
            <!-- Hero Section -->
            <div class="relative overflow-hidden bg-gradient-to-br from-gray-50 to-white py-20">
                <div class="absolute top-0 right-0 -mr-20 -mt-20 w-96 h-96 rounded-full bg-primary/10 blur-3xl"></div>
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
                    <h1 class="text-4xl tracking-tight font-extrabold text-gray-900 sm:text-5xl md:text-6xl">
                        <% if (prodottiData && prodottiData.Title) { %>
                            <span class="block"><%= prodottiData.Title %></span>
                            <span class="block text-primary"><%= prodottiData.Title2 || '' %></span>
                        <% } else { %>
                            <span class="block">Semplifica le tue Operazioni</span>
                            <span class="block text-primary">con Software Intelligenti</span>
                        <% } %>
                    </h1>
                    <p class="mt-3 max-w-md mx-auto text-base text-gray-500 sm:text-lg md:mt-5 md:text-xl md:max-w-3xl">
                        <%= (prodottiData && prodottiData.subtitle) || '' %>
                    </p>
                </div>
            </div>

            <!-- Products Section -->
            <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-24">

                <% if (prodotti && prodotti.length > 0) { %>
                    <% prodotti.forEach(function(prod, idx) { %>

                        <%
                            var colorBg = (prod.IconColor === 'purple') ? 'bg-purple-100' : 'bg-primary/10';
                            var colorText = (prod.IconColor === 'purple') ? 'text-purple-600' : 'text-primary';
                            var colorLink = (prod.IconColor === 'purple') ? 'text-purple-600 hover:text-purple-700' : 'text-primary hover:text-primary-dark';
                        %>

                        <% if (prod.Stile === 'stile-2') { %>
                            <!-- ═══════════════ STILE 2 (tipo Open4US) ═══════════════ -->
                            <div class="lg:grid lg:grid-cols-12 lg:gap-16 items-center">
                                <!-- Colonna SX: Immagine Principale (sfondo grande) + Immagine Secondaria (circolare davanti) -->
                                <div class="lg:col-span-6">
                                    <div class="relative">
                                        <% if (prod.ImmaginePrincipale) { %>
                                            <!-- Immagine principale come sfondo grande -->
                                            <div class="rounded-xl shadow-2xl overflow-hidden relative z-10 card-hover">
                                                <img src="<%= strapiUrl + prod.ImmaginePrincipale.url %>"
                                                    alt="<%= prod.ImmaginePrincipale.alternativeText || (prod.Nome + ' preview') %>"
                                                    class="w-full h-auto object-cover">
                                            </div>
                                        <% } %>
                                        <!-- Immagine secondaria circolare davanti -->
                                        <div class="<%= (prod.ImmaginePrincipale) ? 'absolute -right-12 -bottom-10 z-20 w-48 h-48 lg:w-64 lg:h-64' : 'w-full flex justify-center' %> filter drop-shadow-2xl float-animation">
                                            <div class="relative w-full h-full bg-white rounded-full flex items-center justify-center border-4 border-white overflow-hidden shadow-2xl">
                                                <% if (prod.ImmagineSecondaria) { %>
                                                    <img src="<%= strapiUrl + prod.ImmagineSecondaria.url %>"
                                                        alt="<%= prod.ImmagineSecondaria.alternativeText || prod.Nome %>"
                                                        class="w-full h-full object-cover">
                                                <% } else { %>
                                                    <div class="w-full h-full bg-gray-100 flex items-center justify-center">
                                                        <span class="material-icons text-gray-300 text-6xl"><%= prod.Icona || '' %></span>
                                                    </div>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Colonna DX: Testo + Features griglia -->
                                <div class="lg:col-span-6 mt-16 lg:mt-0">
                                    <div class="flex items-center gap-3 mb-4">
                                        <div class="p-2 <%= colorBg %> rounded-lg">
                                            <span class="material-icons <%= colorText %> text-3xl"><%= prod.Icona || '' %></span>
                                        </div>
                                        <h2 class="text-3xl font-bold text-gray-900"><%- prod.Nome %></h2>
                                    </div>
                                    <% if (prod.Sottotitolo) { %>
                                        <h3 class="text-xl font-medium text-gray-500 mb-6"><%= prod.Sottotitolo %></h3>
                                    <% } %>
                                    <% if (prod.Descrizione) { %>
                                        <p class="text-lg text-gray-600 mb-8 leading-relaxed"><%= prod.Descrizione %></p>
                                    <% } %>
                                    <!-- Features come griglia 2x2 -->
                                    <% if (prod.Features && prod.Features.length > 0) { %>
                                        <div class="grid sm:grid-cols-2 gap-6 mb-8">
                                            <% prod.Features.forEach(function(feat) { %>
                                                <div class="bg-white p-4 rounded-lg border border-gray-100 shadow-sm card-hover">
                                                    <span class="material-icons <%= colorText %> mb-2"><%= feat.Icon || '' %></span>
                                                    <h4 class="font-bold text-gray-900"><%= feat.Title %></h4>
                                                    <% if (feat.Description) { %>
                                                        <p class="text-sm text-gray-500 mt-1"><%= feat.Description %></p>
                                                    <% } %>
                                                </div>
                                            <% }); %>
                                        </div>
                                    <% } %>
                                    <% if (prod.CtaTesto) { %>
                                        <a href="<%= prod.CtaLink || '#' %>"
                                            class="<%= colorLink %> font-semibold inline-flex items-center group transition-colors">
                                            <%= prod.CtaTesto %>
                                            <span class="material-icons ml-2 group-hover:translate-x-1 transition-transform text-sm"><%= prod.CtaIcona || '' %></span>
                                        </a>
                                    <% } %>
                                </div>
                            </div>

                        <% } else { %>
                            <!-- ═══════════════ STILE 1 (tipo CarFleet) ═══════════════ -->
                            <div class="lg:grid lg:grid-cols-12 lg:gap-16 items-center">
                                <!-- Colonna SX: Testo + Features lista -->
                                <div class="lg:col-span-5 order-2 lg:order-1 mt-10 lg:mt-0">
                                    <div class="flex items-center gap-3 mb-4">
                                        <div class="p-2 <%= colorBg %> rounded-lg">
                                            <span class="material-icons <%= colorText %> text-3xl"><%= prod.Icona || '' %></span>
                                        </div>
                                        <h2 class="text-3xl font-bold text-gray-900"><%- prod.Nome %></h2>
                                    </div>
                                    <% if (prod.Sottotitolo) { %>
                                        <h3 class="text-xl font-medium text-gray-500 mb-6"><%= prod.Sottotitolo %></h3>
                                    <% } %>
                                    <% if (prod.Descrizione) { %>
                                        <p class="text-lg text-gray-600 mb-8 leading-relaxed"><%= prod.Descrizione %></p>
                                    <% } %>
                                    <!-- Features come lista con icone -->
                                    <% if (prod.Features && prod.Features.length > 0) { %>
                                        <ul class="space-y-4 mb-8">
                                            <% prod.Features.forEach(function(feat) { %>
                                                <li class="flex items-start">
                                                    <span class="material-icons <%= colorText %> mr-3 mt-1"><%= feat.Icon || '' %></span>
                                                    <div>
                                                        <span class="font-semibold text-gray-900"><%= feat.Title %></span>
                                                        <% if (feat.Description) { %>
                                                            <p class="text-sm text-gray-500"><%= feat.Description %></p>
                                                        <% } %>
                                                    </div>
                                                </li>
                                            <% }); %>
                                        </ul>
                                    <% } %>
                                    <% if (prod.CtaTesto) { %>
                                        <a href="<%= prod.CtaLink || '#' %>"
                                            class="<%= colorLink %> font-semibold inline-flex items-center group transition-colors">
                                            <%= prod.CtaTesto %>
                                            <span class="material-icons ml-2 group-hover:translate-x-1 transition-transform text-sm"><%= prod.CtaIcona || '' %></span>
                                        </a>
                                    <% } %>
                                </div>

                                <!-- Colonna DX: Immagine principale -->
                                <div class="lg:col-span-7 order-1 lg:order-2">
                                    <div class="relative rounded-xl shadow-2xl overflow-hidden transform hover:scale-[1.02] transition-transform duration-500 card-hover">
                                        <% if (prod.ImmaginePrincipale) { %>
                                            <img src="<%= strapiUrl + prod.ImmaginePrincipale.url %>"
                                                alt="<%= prod.ImmaginePrincipale.alternativeText || prod.Nome %>"
                                                class="w-full h-auto object-cover">
                                        <% } else { %>
                                            <div class="w-full h-64 bg-gray-100 flex items-center justify-center">
                                                <span class="material-icons text-gray-300 text-8xl"><%= prod.Icona || '' %></span>
                                            </div>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        <% } %>

                        <!-- Divider (non dopo l'ultimo prodotto) -->
                        <% if (idx < prodotti.length - 1) { %>
                            <div class="relative">
                                <div aria-hidden="true" class="absolute inset-0 flex items-center">
                                    <div class="w-full border-t border-gray-200"></div>
                                </div>
                            </div>
                        <% } %>

                    <% }); %>

                <% } else { %>
                    <!-- Fallback statico se nessun prodotto dal CMS -->
                    <div class="text-center py-16">
                        <span class="material-icons text-gray-300 text-6xl mb-4">inventory_2</span>
                        <p class="text-gray-400 text-lg">I prodotti verranno caricati dal CMS.</p>
                    </div>
                <% } %>

            </section>
        </main>

        <%- include('partials/footer') %>

        <script>
            (function(){var s=document.getElementById('page-skeleton');var c=document.getElementById('page-content');function show(){if(s)s.classList.add('hidden');if(c){c.classList.remove('hidden');c.classList.remove('opacity-0');}}if(document.readyState==='complete')show();else window.addEventListener('load',show);})();
        </script>
</body>

</html>