<!DOCTYPE html>
<html class="scroll-smooth" lang="it">

<head>
    <%- include('partials/head') %>
</head>

<body class="bg-background-light text-secondary font-sans transition-colors duration-300">
    <%- include('partials/topNav') %>
        <%- include('partials/skeleton-page') %>

            <main id="page-content"
                            class="flex-1 max-w-7xl mx-auto w-full px-6 lg:px-20 py-12 hidden opacity-0 transition-opacity duration-300">
                            <% const mainSections=(teamData && teamData.MainTitleSection) || []; const
                                headerSection=mainSections.find(s=> s.__component === 'shared.title') || {};
                                const ctaSection = mainSections.find(s => s.__component === 'shared.button-cta') || {};
                                const ctaUsage = (ctaSection && (ctaSection.Usage || ctaSection.usage || '') ||
                                '').toLowerCase() ||
                                'link';
                                const ctaHref = (ctaSection && ctaSection.href) || '/carriere';
                                const statsSection = mainSections.find(s => s.__component === 'shared.card-content') ||
                                {};
                                const statsTags = Array.isArray(statsSection.tags) ? statsSection.tags : [];
                                const statsImage = statsSection.Image || null;
                                const statsImageUrl = statsImage && statsImage.url ? (strapiUrl + statsImage.url) :
                                null;
                                %>

                                <!-- Page Header -->
                                <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
                                    <div class="max-w-2xl">
                                        <h1
                                            class="text-slate-900 dark:text-slate-100 text-4xl lg:text-5xl font-black leading-tight tracking-tight mb-4">
                                            <%= headerSection.Title || 'Il Nostro Team' %>
                                        </h1>
                                        <p class="text-slate-600 dark:text-slate-400 text-lg leading-relaxed">
                                            <%= headerSection.Description || 'Incontra i professionisti che guidano l\'innovazione in B4US. Un gruppo eterogeneo di esperti dedicato alla trasformazione digitale.' %>
                                        </p>
                                    </div>
                                    <% if (ctaUsage==='modale' || ctaUsage==='modal' ) { %>
                                        <button type="button" onclick="openApplicationModal(null)"
                                            class="flex items-center justify-center gap-2 rounded-lg h-12 px-6 bg-slate-100 dark:bg-slate-800 text-slate-900 dark:text-slate-100 text-sm font-bold hover:bg-primary/20 transition-all group">
                                            <span
                                                class="material-symbols-outlined text-xl group-hover:text-primary">group_add</span>
                                            <%= ctaSection.Label || 'Lavora con noi' %>
                                        </button>
                                        <% } else { %>
                                            <a href="<%= ctaHref %>"
                                                class="flex items-center justify-center gap-2 rounded-lg h-12 px-6 bg-slate-100 dark:bg-slate-800 text-slate-900 dark:text-slate-100 text-sm font-bold hover:bg-primary/20 transition-all group">
                                                <span
                                                    class="material-symbols-outlined text-xl group-hover:text-primary">group_add</span>
                                                <%= ctaSection.Label || 'Lavora con noi' %>
                                            </a>
                                            <% } %>
                                </div>

                                <!-- Filters -->
                                <div class="flex overflow-x-auto pb-4 gap-4 mb-8 no-scrollbar">
                                    <a href="/team"
                                        class="px-6 py-2 rounded-full font-bold text-sm whitespace-nowrap transition-all <%= selectedTeam === 'all' ? 'bg-primary text-background-dark' : 'bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:bg-primary/20' %>">
                                        Tutti
                                    </a>
                                    <% teamRoles.forEach(function(role){ %>
                                        <a href="/team?team=<%= role.documentId %>"
                                            class="px-6 py-2 rounded-full font-bold text-sm whitespace-nowrap transition-all <%= selectedTeam === role.documentId ? 'bg-primary text-background-dark' : 'bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:bg-primary/20' %>">
                                            <%= role.name %>
                                        </a>
                                        <% }); %>
                                </div>

                                <!-- Team Grid -->
                                <div id="team-grid"
                                    class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
                                    <% if (!employees || !employees.length) { %>
                                        <p class="text-slate-500 dark:text-slate-400 col-span-full text-sm">
                                            Nessun membro del team trovato per questo filtro.
                                        </p>
                                    <% } %>
                                    <% (employees || []).forEach(function(m){ %>
                                        <div
                                            class="bg-white dark:bg-slate-900 rounded-xl overflow-hidden border border-slate-200 dark:border-slate-800 hover:border-primary/50 transition-all group">
                                            <div class="aspect-square w-full relative overflow-hidden">
                                                <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                                    alt="Ritratto professionale di <%= m.fullName || 'Membro del team' %>"
                                                    src="<%= m.imageUrl %>" />
                                                <% if (m.year) { %>
                                                    <div
                                                        class="absolute bottom-3 left-3 px-3 py-1 bg-primary text-background-dark text-xs font-bold rounded-full">
                                                        Dal <%= m.year %>
                                                    </div>
                                                <% } %>
                                            </div>
                                            <div class="p-6">
                                                <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100 mb-1">
                                                    <%= m.fullName || 'Membro del team' %>
                                                </h3>
                                                <p class="text-primary text-sm font-semibold uppercase tracking-wider mb-2">
                                                    <%= m.jobTitle %>
                                                </p>
                                                <% if (m.teams && m.teams.length) { %>
                                                    <p class="text-xs text-slate-500 mb-3">
                                                        Team:
                                                        <%= m.teams.map(function(t){ return t.name; }).join(', ') %>
                                                    </p>
                                                <% } %>
                                                <p
                                                    class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed italic border-l-2 border-primary/30 pl-3">
                                                    <%= m.jobDescription %>
                                                </p>
                                            </div>
                                        </div>
                                    <% }); %>
                                </div>

        <!-- Load More -->
        <% if (employees && employees.length > 8) { %>
            <div class="flex justify-center mt-8">
                <button id="load-more-team"
                    class="px-8 py-2 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-200 text-sm font-bold hover:bg-primary/20 hover:text-primary transition-all">
                    Carica altro
                </button>
            </div>
        <% } %>

        <!-- Team Stats Section -->
        <div class="mt-24 bg-white dark:bg-slate-900 rounded-2xl p-10 lg:p-16 border border-slate-200 dark:border-slate-800">
            <div class="flex flex-col lg:flex-row gap-12 items-center">
                <div class="lg:w-1/2">
                    <h2 class="text-slate-900 dark:text-slate-100 text-3xl font-black mb-6">
                        <%= statsSection.Title || ' Insieme facciamo la differenza' %>
                                                                                </h2>
                                                                                <p
                                                                                    class="text-slate-600 dark:text-slate-400 text-lg leading-relaxed mb-8">
                                                                                    <%= statsSection.Description
                                                                                        || 'Il nostro team non è solo composto da colleghi, ma da una comunità di talenti che collaborano ogni giorno per superare le sfide tecnologiche. La nostra forza risiede nella nostra diversità di competenze.'
                                                                                        %>
                                                                                </p>
                                                                                <div class="grid grid-cols-2 gap-8">
                                                                                    <% if (statsTags.length) { %>
                                                                                        <% statsTags.forEach(function(tag)
                                                                                            { %>
                                                                                            <div>
                                                                                                <p
                                                                                                    class="text-4xl font-black text-primary mb-1">
                                                                                                    <%= (tag.tagValue
                                                                                                        || '' ).trim()
                                                                                                        %>
                                                                                                </p>
                                                                                                <p
                                                                                                    class="text-slate-500 text-sm font-medium">
                                                                                                    <%= tag.Tag || '' %>
                                                                                                </p>
                                                                                            </div>
                                                                                            <% }); %>
                                                                                                <% } else { %>
                                                                                                    <div>
                                                                                                        <p
                                                                                                            class="text-4xl font-black text-primary mb-1">
                                                                                                            25+</p>
                                                                                                        <p
                                                                                                            class="text-slate-500 text-sm font-medium">
                                                                                                            Professionisti
                                                                                                        </p>
                                                                                                    </div>
                                                                                                    <div>
                                                                                                        <p
                                                                                                            class="text-4xl font-black text-primary mb-1">
                                                                                                            100+</p>
                                                                                                        <p
                                                                                                            class="text-slate-500 text-sm font-medium">
                                                                                                            Progetti
                                                                                                            completati
                                                                                                        </p>
                                                                                                    </div>
                                                                                                    <div>
                                                                                                        <p
                                                                                                            class="text-4xl font-black text-primary mb-1">
                                                                                                            15</p>
                                                                                                        <p
                                                                                                            class="text-slate-500 text-sm font-medium">
                                                                                                            Anni di
                                                                                                            esperienza
                                                                                                        </p>
                                                                                                    </div>
                                                                                                    <div>
                                                                                                        <p
                                                                                                            class="text-4xl font-black text-primary mb-1">
                                                                                                            10</p>
                                                                                                        <p
                                                                                                            class="text-slate-500 text-sm font-medium">
                                                                                                            Certificazioni
                                                                                                            Core</p>
                                                                                                    </div>
                                                                                                    <% } %>
                                                                                </div>
                                                                </div>
                                                                <div class="lg:w-1/2 w-full">
                                                                    <div
                                                                        class="aspect-video rounded-xl overflow-hidden shadow-2xl">
                                                                        <img class="w-full h-full object-cover"
                                                                            alt="Il team B4US al lavoro in ufficio"
                                                                            src="<%= statsImageUrl || 'https://lh3.googleusercontent.com/aida-public/AB6AXuC_ZjmSRj4IPoGj6o0_q7fjFmH0CH53UiNHVwj-u8uwEZoJhLvXX6qiQdSW119areKb8m6niWeF-bIBNH-1qzkm2IJJuoEjKLHQYzxXTb82zvWwGoEXjUJ9gdgArqBGyTdLjcjg675cOGnrzjK30pkZs2Y2713zjfGT8DXA6OYSmd4pBI_gUUmUJn588S-51zOJyEjoqsn3NX3aHFFTT94TWFnI5BVBYTI1Ecweu6uEDyV1f8t7S5cD91SYXjCJD3xW_4ai6px2TTaP' %>" />
                                                                    </div>
                                                                </div>
                                                            </div>
                                            </div>
                        </main>

            <!-- Modale Candidatura (riuso da carriere.ejs, per usage=modale) -->
            <div id="applicationModal"
                class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
                <div
                    class="bg-white dark:bg-slate-800 rounded-2xl shadow-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto">
                    <div
                        class="p-6 border-b border-slate-200 dark:border-slate-700 flex justify-between items-center sticky top-0 bg-white dark:bg-slate-800">
                        <h3 class="text-2xl font-bold">Candidati alla posizione</h3>
                        <button onclick="closeApplicationModal()"
                            class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200">
                            <span class="material-symbols-outlined">close</span>
                        </button>
                    </div>

                    <form id="applicationForm" class="p-6 space-y-4" enctype="multipart/form-data">
                        <div class="grid md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium mb-2">Nome *</label>
                                <input type="text" name="nome" required
                                    class="w-full px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 focus:ring-2 focus:ring-primary focus:border-transparent">
                            </div>
                            <div>
                                <label class="block text-sm font-medium mb-2">Cognome *</label>
                                <input type="text" name="cognome" required
                                    class="w-full px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 focus:ring-2 focus:ring-primary focus:border-transparent">
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium mb-2">Data di Nascita *</label>
                            <input type="date" name="dataNascita" required
                                class="w-full px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 focus:ring-2 focus:ring-primary focus:border-transparent">
                        </div>

                        <div class="grid md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium mb-2">Email *</label>
                                <input type="email" name="email" required
                                    class="w-full px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 focus:ring-2 focus:ring-primary focus:border-transparent">
                            </div>
                            <div>
                                <label class="block text-sm font-medium mb-2">Telefono *</label>
                                <input type="tel" name="telefono" required
                                    class="w-full px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 focus:ring-2 focus:ring-primary focus:border-transparent">
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium mb-2">Posizione *</label>
                            <select name="jobPosition" id="jobPositionSelect" required
                                class="w-full px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 focus:ring-2 focus:ring-primary focus:border-transparent">
                                <option value="">Seleziona una posizione</option>
                                <option value="autocandidatura">Auto Candidatura</option>
                                <% if (jobPositions && jobPositions.length > 0) { %>
                                    <% jobPositions.forEach(function(job) { %>
                                        <option value="<%= job.id %>"><%= job.titolo %></option>
                                    <% }); %>
                                <% } %>
                            </select>
                        </div>

                        <div>
                            <label class="block text-sm font-medium mb-2">Carica il tuo CV * (PDF, DOC, DOCX)</label>
                            <input type="file" name="cv" required accept=".pdf,.doc,.docx"
                                class="w-full px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 focus:ring-2 focus:ring-primary focus:border-transparent file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-primary file:text-white file:cursor-pointer hover:file:brightness-110">
                        </div>

                        <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-4">
                            <p class="text-sm text-blue-800 dark:text-blue-300">
                                <span class="material-symbols-outlined text-sm align-middle">info</span>
                                I tuoi dati saranno trattati in conformità con la nostra politica sulla privacy.
                            </p>
                        </div>

                        <div id="submitMessage" class="hidden"></div>

                        <div class="flex gap-4 justify-end pt-4">
                            <button type="button" onclick="closeApplicationModal()"
                                class="px-6 py-2 border border-slate-300 dark:border-slate-600 rounded-lg font-medium hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors">
                                Annulla
                            </button>
                            <button type="submit" id="submitBtn"
                                class="px-6 py-2 bg-primary text-white font-bold rounded-lg hover:brightness-110 transition-all flex items-center gap-2">
                                <span>Invia Candidatura</span>
                                <span class="material-symbols-outlined">send</span>
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <%- include('partials/footer') %>

                <script>
                    (function () {
                        const INITIAL_VISIBLE = 8;
                        const grid = document.getElementById('team-grid');
                        const loadMoreBtn = document.getElementById('load-more-team');
                        if (!grid) return;
                        const cards = Array.from(grid.children).filter(el =>
                            el.classList.contains('bg-white') || el.classList.contains('dark:bg-slate-900')
                        );
                        function updateVisibility() {
                            cards.forEach((card, index) => {
                                if (index < INITIAL_VISIBLE) {
                                    card.classList.remove('hidden');
                                } else {
                                    card.classList.add('hidden');
                                }
                            });
                        }
                        updateVisibility();
                        if (loadMoreBtn) {
                            loadMoreBtn.addEventListener('click', () => {
                                const hiddenCards = cards.filter(c => c.classList.contains('hidden'));
                                hiddenCards.forEach(c => c.classList.remove('hidden'));
                                loadMoreBtn.style.display = 'none';
                            });
                        }
                    })();
                </script>

                <script>
                    const jobPositionsData = <%- JSON.stringify(jobPositions || []) %>;

                    function openApplicationModal(jobId) {
                        const modal = document.getElementById('applicationModal');
                        const select = document.getElementById('jobPositionSelect');
                        modal.classList.remove('hidden');
                        document.body.style.overflow = 'hidden';
                        if (jobId) {
                            select.value = jobId;
                        } else {
                            select.value = 'autocandidatura';
                        }
                    }

                    function closeApplicationModal() {
                        const modal = document.getElementById('applicationModal');
                        if (!modal) return;
                        modal.classList.add('hidden');
                        document.body.style.overflow = '';
                        const form = document.getElementById('applicationForm');
                        if (form) form.reset();
                        const msg = document.getElementById('submitMessage');
                        if (msg) msg.classList.add('hidden');
                    }

                    const modalEl = document.getElementById('applicationModal');
                    if (modalEl) {
                        modalEl.addEventListener('click', function (e) {
                            if (e.target === this) {
                                closeApplicationModal();
                            }
                        });
                    }

                    const appForm = document.getElementById('applicationForm');
                    if (appForm) {
                        appForm.addEventListener('submit', async function (e) {
                            e.preventDefault();
                            const submitBtn = document.getElementById('submitBtn');
                            const messageDiv = document.getElementById('submitMessage');
                            const formData = new FormData(this);
                            submitBtn.disabled = true;
                            submitBtn.innerHTML = '<span>Invio in corso...</span><span class="material-symbols-outlined animate-spin">progress_activity</span>';
                            try {
                                const response = await fetch('/api/job-application', {
                                    method: 'POST',
                                    body: formData
                                });
                                const result = await response.json();
                                if (response.ok && result.success) {
                                    messageDiv.className = 'bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg p-4';
                                    messageDiv.innerHTML = '<p class="text-sm text-green-800 dark:text-green-300"><span class="material-symbols-outlined text-sm align-middle">check_circle</span> ' + result.message + '</p>';
                                    messageDiv.classList.remove('hidden');
                                    setTimeout(() => { closeApplicationModal(); }, 2000);
                                } else {
                                    throw new Error(result.message || 'Errore durante l\'invio');
                                }
                            } catch (error) {
                                messageDiv.className = 'bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4';
                                messageDiv.innerHTML = '<p class="text-sm text-red-800 dark:text-red-300"><span class="material-symbols-outlined text-sm align-middle">error</span> ' + error.message + '</p>';
                                messageDiv.classList.remove('hidden');
                            } finally {
                                submitBtn.disabled = false;
                                submitBtn.innerHTML = '<span>Invia Candidatura</span><span class="material-symbols-outlined">send</span>';
                            }
                        });
                    }
                </script>
                <script>
                    (function(){var s=document.getElementById('page-skeleton');var c=document.getElementById('page-content');function show(){if(s)s.classList.add('hidden');if(c){c.classList.remove('hidden');c.classList.remove('opacity-0');}}if(document.readyState==='complete')show();else window.addEventListener('load',show);})();
                </script>
</body>

</html>