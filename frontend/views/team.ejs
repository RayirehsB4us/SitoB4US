<!DOCTYPE html>
<html class="scroll-smooth" lang="it">

<head>
    <%- include('partials/head') %>
</head>

<body class="bg-background-light text-secondary font-sans transition-colors duration-300">
    <%- include('partials/topNav') %>

    <% 
      const mainSections = (teamData && teamData.MainTitleSection) || [];
      const headerSection = mainSections.find(s => s.__component === 'shared.title') || {};
      const ctaSection = mainSections.find(s => s.__component === 'shared.button-cta') || {};
      const statsSection = mainSections.find(s => s.__component === 'shared.card-content') || {};
      const statsTags = Array.isArray(statsSection.tags) ? statsSection.tags : [];
      const statsImage = statsSection.Image || null;
      const statsImageUrl = statsImage && statsImage.url ? (strapiUrl + statsImage.url) : null;
    %>

    <main class="flex-1 max-w-7xl mx-auto w-full px-6 lg:px-20 py-12">
        <!-- Page Header -->
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
            <div class="max-w-2xl">
                <h1
                    class="text-slate-900 dark:text-slate-100 text-4xl lg:text-5xl font-black leading-tight tracking-tight mb-4">
                    <%= headerSection.Title || 'Il Nostro Team' %>
                </h1>
                <p class="text-slate-600 dark:text-slate-400 text-lg leading-relaxed">
                    <%= headerSection.Description || 'Incontra i professionisti che guidano l\'innovazione in B4US. Un gruppo eterogeneo di esperti dedicato alla trasformazione digitale.' %>
                </p>
            </div>
            <button
                class="flex items-center justify-center gap-2 rounded-lg h-12 px-6 bg-slate-100 dark:bg-slate-800 text-slate-900 dark:text-slate-100 text-sm font-bold hover:bg-primary/20 transition-all group">
                <span class="material-symbols-outlined text-xl group-hover:text-primary">group_add</span>
                <%= ctaSection.Label || 'Lavora con noi' %>
            </button>
        </div>

        <!-- Filters -->
        <div class="flex overflow-x-auto pb-4 gap-4 mb-8 no-scrollbar">
            <button
                class="px-6 py-2 rounded-full bg-primary text-background-dark font-bold text-sm whitespace-nowrap">Tutti</button>
            <button
                class="px-6 py-2 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:bg-primary/20 transition-all font-bold text-sm whitespace-nowrap">Sviluppo</button>
            <button
                class="px-6 py-2 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:bg-primary/20 transition-all font-bold text-sm whitespace-nowrap">Sistemisti</button>
            <button
                class="px-6 py-2 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:bg-primary/20 transition-all font-bold text-sm whitespace-nowrap">Management</button>
            <button
                class="px-6 py-2 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:bg-primary/20 transition-all font-bold text-sm whitespace-nowrap">Marketing</button>
        </div>

        <!-- Team Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
            <!-- Sheriyar Shakeel -->
            <div
                class="bg-white dark:bg-slate-900 rounded-xl overflow-hidden border border-slate-200 dark:border-slate-800 hover:border-primary/50 transition-all group">
                <div class="aspect-square w-full relative overflow-hidden">
                    <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                        alt="Ritratto professionale di Sheriyar Shakeel"
                        src="https://lh3.googleusercontent.com/aida-public/AB6AXuB4srfPjOZatC6BMr-yM2CWtc0fy34EQZWnetY_MAGiU29mXJ1CEswmkkrKb_JbgV9S-DrISbId5lcyqz2Og3x4weC42743xbbJRlnoiQSEx6xCHIUbRpHOSww04KPAovkfAAYrw0G8LEbOsmdOhpryfI1ZtiqavNoG5SR9uqjcetMW2A-D7vquFJBtrc-5hUzm24FXPH2v4wWvNYdz9R8hviP7gIg0wLnhsnRH1MmRyDDANQVNfoZcpSlMXWnRvqCbQ29DPzvDlAQ6" />
                    <div
                        class="absolute bottom-3 left-3 px-3 py-1 bg-primary text-background-dark text-xs font-bold rounded-full">
                        Dal 2021
                    </div>
                </div>
                <div class="p-6">
                    <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100 mb-1">Sheriyar Shakeel</h3>
                    <p class="text-primary text-sm font-semibold uppercase tracking-wider mb-4">Full stack Developer</p>
                    <p
                        class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed italic border-l-2 border-primary/30 pl-3">
                        Esperto in Open4US e nello sviluppo di tecnologie web moderne con focus sulla scalabilità.
                    </p>
                </div>
            </div>

            <!-- Riccardo Germinario -->
