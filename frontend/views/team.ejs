        <!-- Team Stats Section -->
        <div class="mt-24 bg-white dark:bg-slate-900 rounded-2xl p-10 lg:p-16 border border-slate-200 dark:border-slate-800">
            <div class="flex flex-col lg:flex-row gap-12 items-center">
                <div class="lg:w-1/2">
                    <h2 class="text-slate-900 dark:text-slate-100 text-3xl font-black mb-6">
                        <%= statsSection.Title || 'Insieme facciamo la differenza' %>
                    </h2>
                    <p class="text-slate-600 dark:text-slate-400 text-lg leading-relaxed mb-8">
                        <%= statsSection.Description || 'Il nostro team non è solo composto da colleghi, ma da una comunità di talenti che collaborano ogni giorno per superare le sfide tecnologiche. La nostra forza risiede nella nostra diversità di competenze.' %>
                    </p>
                    <div class="grid grid-cols-2 gap-8">
                        <% if (statsTags.length) { %>
                            <% statsTags.forEach(function(tag) { %>
                                <div>
                                    <p class="text-4xl font-black text-primary mb-1"><%= (tag.tagValue || '').trim() %></p>
                                    <p class="text-slate-500 text-sm font-medium"><%= tag.Tag || '' %></p>
                                </div>
                            <% }); %>
                        <% } else { %>
