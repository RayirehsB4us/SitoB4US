                    <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                        alt="Ritratto professionale di Marco Verdi"
                        src="https://lh3.googleusercontent.com/aida-public/AB6AXuBQ8fgV4_dWY2NDi7F6uNTXddfXCZ9Kt3aDIBIykk1VYWkOoCITPZfcr-tEF6SbeLBIOV1XXkiqCAMNFI6RMfUMSlVo7NXsb-4xELF6CeESag_qQKo8Ii0VPirCjrSore59GPb5evNGy9oSvHAhvg0kUBk9dCr1LhmbemsDdhTgqwu_BKBkAWj45vwAhLUw7iO4yYXT6KyVGU_14oqi-qqfm-qpnU2SVoVmzWbrTFxRMv8iogdwTb_hNpnuCvXl8-cr51V9F9OgXxVd" />
                </div>
