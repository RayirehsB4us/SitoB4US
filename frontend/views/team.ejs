                <div class="aspect-square w-full relative overflow-hidden">
                    <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                        alt="Ritratto professionale di Pasquale Lino Schiavone"
                        src="https://lh3.googleusercontent.com/aida-public/AB6AXuDE5zkFRjnf0uv-pmttJlSWGm_mKULK3Q_d4twij3jWV4U5F3sBVaKiBs8-iQD6y7Ci4Q-1QURs_pPGfmOKXqcJx_AdsTA_tpcqD0i1U-Byo158QwqQYUY3dueC9M7TRiqWChXi7m5zVZ36tVcT2qttXsKhouPdf0xoES7mkrrGfQ1QwocJVdHZI1OYNuiAxi6-tFMfb482lYAWgloXe26ybxeGTdaDxcrjmm1qiQb1FLYNO0lxDjJVSBQC61iVoMgyXTZusBm4P2Qx" />
                </div>
