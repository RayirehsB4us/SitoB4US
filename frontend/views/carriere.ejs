<!DOCTYPE html>
<html class="scroll-smooth" lang="it">

<head>
    <%- include('partials/head') %>
</head>

<body class="bg-background-light text-slate-800 font-sans transition-colors duration-300">
    <%- include('partials/navbar') %>

        <section class="relative py-20 overflow-hidden">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
                <div class="grid lg:grid-cols-2 gap-12 items-center">
                    <div>
                        <span
                            class="inline-block py-1 px-3 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-wider mb-4">Carriere
                            in B4US</span>
                        <h1
                            class="text-4xl md:text-6xl font-black font-display text-slate-900 dark:text-white leading-tight mb-6">
                            Costruisci il futuro dell'IT con noi.
                        </h1>
                        <p class="text-lg text-slate-600 dark:text-slate-400 mb-8 max-w-lg leading-relaxed">
                            Siamo alla ricerca di talenti pronti a mettersi in gioco e ad esprimere le proprie capacità. Entra a far parte di un team che valorizza l'innovazione e la
                            crescita personale.
                        </p>
                        <div class="flex flex-wrap gap-4">
                            <a class="px-8 py-4 bg-primary text-white font-bold rounded-lg shadow-lg shadow-primary/30 hover:shadow-xl hover:-translate-y-1 transition-all"
                                href="#positions">
                                Posizioni Aperte
                            </a>
                            <a class="px-8 py-4 bg-white dark:bg-slate-800 text-slate-900 dark:text-white font-bold rounded-lg border border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-700 transition-all"
                                href="#culture">
                                Scopri la nostra cultura
                            </a>
                        </div>
                    </div>
                    <div class="relative">
                        <div
                            class="aspect-square rounded-3xl bg-gradient-to-br from-primary/20 to-blue-500/10 flex items-center justify-center p-8">
                            <img alt="Team collaborativo al lavoro"
                                class="rounded-2xl shadow-2xl object-cover w-full h-full" src="images/2025.jpg" />
                        </div>
                        <div
                            class="absolute -bottom-6 -left-6 bg-white dark:bg-slate-800 p-6 rounded-xl shadow-xl border border-slate-100 dark:border-slate-700 hidden sm:block">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 rounded-full bg-primary flex items-center justify-center">
                                    <span class="material-symbols-outlined text-white">groups</span>
                                </div>
                                <div>
                                    <p class="text-sm font-bold text-slate-900 dark:text-white">+20 Esperti</p>
                                    <p class="text-xs text-slate-500">In tutta Italia</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <section class="py-20" id="culture">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-16">
                    <h2 class="text-3xl md:text-4xl font-black font-display mb-4">Perché scegliere B4US?</h2>
                    <p class="text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">Offriamo un ambiente di lavoro
                        flessibile che premia il merito e incoraggia l'apprendimento continuo.</p>
                </div>
                <div class="grid md:grid-cols-3 gap-8">
                    <div
                        class="bg-white dark:bg-slate-800 p-8 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 hover:shadow-md transition-shadow">
                        <div
                            class="w-12 h-12 bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded-lg flex items-center justify-center mb-6">
                            <span class="material-symbols-outlined">psychology</span>
                        </div>
                        <h3 class="text-xl font-bold mb-3">Crescita Professionale</h3>
                        <p class="text-slate-600 dark:text-slate-400">Piani di formazione personalizzati e
                            certificazioni IT pagate dall'azienda.</p>
                    </div>
                    <div
                        class="bg-white dark:bg-slate-800 p-8 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 hover:shadow-md transition-shadow">
                        <div
                            class="w-12 h-12 bg-primary/10 text-primary rounded-lg flex items-center justify-center mb-6">
                            <span class="material-symbols-outlined">home_work</span>
                        </div>
                        <h3 class="text-xl font-bold mb-3">Smart Working</h3>
                        <p class="text-slate-600 dark:text-slate-400">Flessibilità totale tra ufficio e casa per
                            garantire un equilibrio vita-lavoro sano.</p>
                    </div>
                    <div
                        class="bg-white dark:bg-slate-800 p-8 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 hover:shadow-md transition-shadow">
                        <div
                            class="w-12 h-12 bg-orange-100 dark:bg-orange-900/30 text-orange-600 dark:text-orange-400 rounded-lg flex items-center justify-center mb-6">
                            <span class="material-symbols-outlined">rocket_launch</span>
                        </div>
                        <h3 class="text-xl font-bold mb-3">Progetti Innovativi</h3>
                        <p class="text-slate-600 dark:text-slate-400">Lavora con le ultime tecnologie e su sfide
                            concrete per grandi aziende enterprise.</p>
                    </div>
                </div>
            </div>
        </section>
        <section class="py-20 bg-slate-50 dark:bg-slate-900/20" id="positions">
            <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-6">
                    <div>
                        <h2 class="text-3xl font-black font-display mb-2">Posizioni Aperte</h2>
                        <p class="text-slate-600 dark:text-slate-400">Trova il ruolo perfetto per le tue competenze.</p>
                    </div>
                    <div class="flex gap-4">
                        <select
                            class="rounded-lg border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-sm">
                            <option>Tutti i reparti</option>
                            <option>Sviluppo</option>
                            <option>Infrastruttura</option>
                            <option>Cybersecurity</option>
                        </select>
                    </div>
                </div>
                <div class="space-y-4">
                    <% if (jobPositions && jobPositions.length> 0) { %>
                        <% jobPositions.forEach(function(job) { %>
                            <details
                                class="group bg-white dark:bg-slate-800 rounded-xl shadow-sm border border-slate-100 dark:border-slate-700 overflow-hidden transition-all duration-300">
                                <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
                                    <div class="flex items-center gap-6">
                                        <div
                                            class="hidden sm:flex w-12 h-12 bg-primary/5 rounded-full items-center justify-center text-primary">
                                            <span class="material-symbols-outlined">
                                                <%= job.icona || 'work' %>
                                            </span>
                                        </div>
                                        <div>
                                            <h4 class="text-lg font-bold group-hover:text-primary transition-colors">
                                                <%= job.titolo %>
                                            </h4>
                                            <div class="flex gap-4 mt-1 text-xs text-slate-500 dark:text-slate-400">
                                                <% if (job.location) { %>
                                                    <span class="flex items-center gap-1"><span
                                                            class="material-symbols-outlined text-sm">location_on</span>
                                                        <%= job.location %>
                                                    </span>
                                                    <% } %>
                                                        <% if (job.tipologia) { %>
                                                            <span class="flex items-center gap-1"><span
                                                                    class="material-symbols-outlined text-sm">schedule</span>
                                                                <%= job.tipologia %>
                                                            </span>
                                                            <% } %>
                                            </div>
                                        </div>
                                    </div>
                                    <span
                                        class="material-symbols-outlined group-open:rotate-180 transition-transform text-slate-400">expand_more</span>
                                </summary>
                                <div class="px-6 pb-6 pt-2 border-t border-slate-50 dark:border-slate-700/50">
                                    <div class="prose prose-slate dark:prose-invert max-w-none text-sm leading-relaxed">
                                        <%- job.descrizione %>
                                    </div>
                                    <div class="mt-8 flex justify-end">
                                        <button onclick="openApplicationModal(<%= job.id || 'null' %>)"
                                            class="px-6 py-2 bg-primary text-white font-bold rounded-lg hover:brightness-110 transition-all">
                                            Candidati Ora
                                        </button>
                                    </div>
                                </div>
                            </details>
                            <% }); %>
                                <% } else { %>
                                    <div class="text-center py-12 text-slate-500">
                                        Nessuna posizione aperta al momento. Controlla più tardi!
                                    </div>
                                    <% } %>
                </div>
                <div class="mt-12 p-8 bg-primary/5 rounded-2xl border-2 border-dashed border-primary/20 text-center">
                    <p class="text-lg font-medium mb-4">Non trovi la posizione giusta per te?</p>
                    <p class="text-slate-600 dark:text-slate-400 mb-6">Siamo sempre alla ricerca di persone brillanti.
                        Inviaci la tua candidatura spontanea.</p>
                    <button onclick="openApplicationModal(null)"
                        class="inline-flex items-center gap-2 text-primary font-bold hover:underline">
                        Invia CV Spontaneo <span class="material-symbols-outlined">arrow_forward</span>
                    </button>
                </div>
            </div>
        </section>
        <section class="py-20">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div
                    class="bg-slate-900 dark:bg-slate-800 rounded-[2rem] p-8 md:p-16 relative overflow-hidden text-center text-white">
                    <div class="relative z-10 max-w-2xl mx-auto">
                        <h2 class="text-3xl md:text-5xl font-black font-display mb-6">Pronto per la tua prossima sfida?
                        </h2>
                        <p class="text-slate-300 text-lg mb-10 leading-relaxed">
                            B4US non è solo un posto di lavoro, è un ambiente dove le tue idee diventano realtà.
                            Unisciti a noi e semplifichiamo l'IT insieme.
                        </p>
                        <a class="inline-block px-10 py-5 bg-primary text-white font-black text-xl rounded-xl shadow-2xl hover:scale-105 transition-transform"
                            href="#positions">
                            Apply Now
                        </a>
                    </div>
                    <div
                        class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/2 w-64 h-64 bg-primary/20 rounded-full blur-3xl">
                    </div>
                    <div
                        class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-64 h-64 bg-blue-500/20 rounded-full blur-3xl">
                    </div>
                </div>
            </div>
        </section>

        <%- include('partials/footer') %>

            <!-- Modale Candidatura -->
            <div id="applicationModal"
                class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
                <div
                    class="bg-white dark:bg-slate-800 rounded-2xl shadow-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto">
                    <div
                        class="p-6 border-b border-slate-200 dark:border-slate-700 flex justify-between items-center sticky top-0 bg-white dark:bg-slate-800">
                        <h3 class="text-2xl font-bold">Candidati alla posizione</h3>
                        <button onclick="closeApplicationModal()"
                            class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200">
                            <span class="material-symbols-outlined">close</span>
                        </button>
                    </div>

                    <form id="applicationForm" class="p-6 space-y-4">
                        <div class="grid md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium mb-2">Nome *</label>
                                <input type="text" name="nome" required
                                    class="w-full px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 focus:ring-2 focus:ring-primary focus:border-transparent">
                            </div>
                            <div>
                                <label class="block text-sm font-medium mb-2">Cognome *</label>
                                <input type="text" name="cognome" required
                                    class="w-full px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 focus:ring-2 focus:ring-primary focus:border-transparent">
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium mb-2">Data di Nascita *</label>
                            <input type="date" name="dataNascita" required
                                class="w-full px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 focus:ring-2 focus:ring-primary focus:border-transparent">
                        </div>

                        <div class="grid md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium mb-2">Email *</label>
                                <input type="email" name="email" required
                                    class="w-full px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 focus:ring-2 focus:ring-primary focus:border-transparent">
                            </div>
                            <div>
                                <label class="block text-sm font-medium mb-2">Telefono *</label>
                                <input type="tel" name="telefono" required
                                    class="w-full px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 focus:ring-2 focus:ring-primary focus:border-transparent">
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium mb-2">Posizione *</label>
                            <select name="jobPosition" id="jobPositionSelect" required
                                class="w-full px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 focus:ring-2 focus:ring-primary focus:border-transparent">
                                <option value="">Seleziona una posizione</option>
                                <option value="autocandidatura">Auto Candidatura</option>
                                <% if (jobPositions && jobPositions.length> 0) { %>
                                    <% jobPositions.forEach(function(job) { %>
                                        <option value="<%= job.id %>">
                                            <%= job.titolo %>
                                        </option>
                                        <% }); %>
                                            <% } %>
                            </select>
                        </div>

                        <div>
                            <label class="block text-sm font-medium mb-2">Carica il tuo CV * (PDF, DOC, DOCX)</label>
                            <input type="file" name="cv" required accept=".pdf,.doc,.docx"
                                class="w-full px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 focus:ring-2 focus:ring-primary focus:border-transparent file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-primary file:text-white file:cursor-pointer hover:file:brightness-110">
                        </div>

                        <div
                            class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-4">
                            <p class="text-sm text-blue-800 dark:text-blue-300">
                                <span class="material-symbols-outlined text-sm align-middle">info</span>
                                I tuoi dati saranno trattati in conformità con la nostra politica sulla privacy.
                            </p>
                        </div>

                        <div id="submitMessage" class="hidden"></div>

                        <div class="flex gap-4 justify-end pt-4">
                            <button type="button" onclick="closeApplicationModal()"
                                class="px-6 py-2 border border-slate-300 dark:border-slate-600 rounded-lg font-medium hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors">
                                Annulla
                            </button>
                            <button type="submit" id="submitBtn"
                                class="px-6 py-2 bg-primary text-white font-bold rounded-lg hover:brightness-110 transition-all flex items-center gap-2">
                                <span>Invia Candidatura</span>
                                <span class="material-symbols-outlined">send</span>
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <script>
                let selectedJobId = null;
                const jobPositionsData = <%- JSON.stringify(jobPositions || []) %>;

                function openApplicationModal(jobId) {
                    selectedJobId = jobId;
                    const modal = document.getElementById('applicationModal');
                    const select = document.getElementById('jobPositionSelect');

                    modal.classList.remove('hidden');
                    document.body.style.overflow = 'hidden';

                    // Se è stato selezionato un lavoro specifico, preselezionalo
                    if (jobId) {
                        select.value = jobId;
                    } else {
                        select.value = 'autocandidatura';
                    }
                }

                function closeApplicationModal() {
                    const modal = document.getElementById('applicationModal');
                    modal.classList.add('hidden');
                    document.body.style.overflow = '';
                    document.getElementById('applicationForm').reset();
                    document.getElementById('submitMessage').classList.add('hidden');
                    selectedJobId = null;
                }

                // Chiudi il modale cliccando fuori
                document.getElementById('applicationModal').addEventListener('click', function (e) {
                    if (e.target === this) {
                        closeApplicationModal();
                    }
                });

                // Gestisci l'invio del form
                document.getElementById('applicationForm').addEventListener('submit', async function (e) {
                    e.preventDefault();

                    const submitBtn = document.getElementById('submitBtn');
                    const messageDiv = document.getElementById('submitMessage');
                    const formData = new FormData(this);

                    // Disabilita il pulsante durante l'invio
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<span>Invio in corso...</span><span class="material-symbols-outlined animate-spin">progress_activity</span>';

                    try {
                        const response = await fetch('/api/job-application', {
                            method: 'POST',
                            body: formData
                        });

                        const result = await response.json();

                        if (response.ok && result.success) {
                            messageDiv.className = 'bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg p-4';
                            messageDiv.innerHTML = `
                        <p class="text-sm text-green-800 dark:text-green-300">
                            <span class="material-symbols-outlined text-sm align-middle">check_circle</span>
                            ${result.message}
                        </p>
                    `;
                            messageDiv.classList.remove('hidden');

                            // Chiudi il modale dopo 2 secondi
                            setTimeout(() => {
                                closeApplicationModal();
                            }, 2000);
                        } else {
                            throw new Error(result.message || 'Errore durante l\'invio');
                        }
                    } catch (error) {
                        messageDiv.className = 'bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4';
                        messageDiv.innerHTML = `
                    <p class="text-sm text-red-800 dark:text-red-300">
                        <span class="material-symbols-outlined text-sm align-middle">error</span>
                        ${error.message}
                    </p>
                `;
                        messageDiv.classList.remove('hidden');
                    } finally {
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = '<span>Invia Candidatura</span><span class="material-symbols-outlined">send</span>';
                    }
                });
            </script>
</body>

</html>