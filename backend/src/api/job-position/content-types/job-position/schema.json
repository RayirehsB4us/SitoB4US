{
  "kind": "collectionType",
  "collectionName": "job_positions",
  "info": {
    "singularName": "job-position",
    "pluralName": "job-positions",
    "displayName": "Lista Annunci di lavoro",
    "description": "Posizioni lavorative aperte"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "titolo": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "titolo"
    },
    "descrizione": {
      "type": "richtext",
      "customField": "plugin::ckeditor5.CKEditor",
      "required": true,
      "options": {
        "preset": "defaultHtml"
      }
    },
    "location": {
      "type": "string"
    },
    "tipologia": {
      "type": "enumeration",
      "enum": [
        "Full-time",
        "Part-time",
        "Remote",
        "Hybrid"
      ]
    },
    "reparto": {
      "type": "string"
    },
    "icona": {
      "type": "string",
      "customField": "plugin::icon-picker.icon"
    },
    "requisiti": {
      "type": "richtext",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "attiva": {
      "type": "boolean",
      "default": true
    },
    "ordine": {
      "type": "integer",
      "default": 0
    }
  }
}
