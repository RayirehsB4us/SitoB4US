{
  "kind": "singleType",
  "collectionName": "contatti",
  "info": {
    "singularName": "contatti",
    "pluralName": "contatti-list",
    "displayName": "Pagina Contatti"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "MainTitle": {
      "type": "string",
      "required": true
    },
    "Description": {
      "type": "richtext",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "FormTitle": {
      "type": "string"
    },
    "ContactDetails": {
      "type": "component",
      "component": "contatti.contact-detail",
      "repeatable": true
    },
    "SedeTitle": {
      "type": "string"
    },
    "SedeAddress": {
      "type": "text"
    },
    "SedeMapUrl": {
      "type": "string"
    }
  }
}
