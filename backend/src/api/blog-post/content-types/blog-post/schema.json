{
  "kind": "collectionType",
  "collectionName": "blog_posts",
  "info": {
    "singularName": "blog-post",
    "pluralName": "blog-posts",
    "displayName": "Lista Articolo Blog",
    "description": "Articoli del blog aziendale"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "titolo": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "titolo"
    },
    "descrizione": {
      "type": "text",
      "required": true
    },
    "contenuto": {
      "type": "richtext"
    },
    "immagine": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "categoria": {
      "type": "string"
    },
    "dataPublicazione": {
      "type": "date"
    },
    "tempoLettura": {
      "type": "integer",
      "default": 5
    }
  }
}
