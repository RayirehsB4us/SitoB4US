{
  "kind": "collectionType",
  "collectionName": "job_requests",
  "info": {
    "singularName": "job-request",
    "pluralName": "job-requests",
    "displayName": "jobRequest",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Nome": {
      "type": "string"
    },
    "Cognome": {
      "type": "string"
    },
    "AnnoNascita": {
      "type": "date"
    },
    "email": {
      "type": "email"
    },
    "Telefono": {
      "type": "string"
    },
    "cv": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "job_position": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::job-position.job-position"
    }
  }
}
