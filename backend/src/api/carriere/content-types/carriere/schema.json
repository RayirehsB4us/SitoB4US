{
  "kind": "singleType",
  "collectionName": "carriere",
  "info": {
    "singularName": "carriere",
    "pluralName": "carrieres",
    "displayName": "Pagina Carriere"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "UpperTitle": {
      "type": "string"
    },
    "MainTitle": {
      "type": "string",
      "required": true
    },
    "Description": {
      "type": "richtext",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "Button1Text": {
      "type": "string"
    },
    "Button2Text": {
      "type": "string"
    },
    "HeroImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "CultureTitle": {
      "type": "string"
    },
    "CultureSubTitle": {
      "type": "richtext",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "CultureCards": {
      "type": "component",
      "component": "carriere.culture-card",
      "repeatable": true
    },
    "PositionsTitle": {
      "type": "string"
    },
    "PositionsSubTitle": {
      "type": "text"
    },
    "SpontaneousTitle": {
      "type": "string"
    },
    "SpontaneousSubTitle": {
      "type": "text"
    },
    "SpontaneousLinkText": {
      "type": "string"
    },
    "BottomCtaTitle": {
      "type": "string"
    },
    "BottomCtaSubTitle": {
      "type": "richtext",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "BottomCtaButton": {
      "type": "string"
    }
  }
}
