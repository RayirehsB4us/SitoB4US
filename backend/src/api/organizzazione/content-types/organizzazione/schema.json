{
  "kind": "singleType",
  "collectionName": "organizzazioni",
  "info": {
    "singularName": "organizzazione",
    "pluralName": "organizzazioni",
    "displayName": "Pagina Organizzazione"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "MainTitle": {
      "type": "string",
      "required": true
    },
    "descriptionTitle": {
      "type": "richtext",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "CoverImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "HeroSection": {
      "type": "component",
      "component": "organizzazione.hero-section",
      "repeatable": true
    },
    "techArea": {
      "type": "component",
      "component": "organizzazione.tech-area",
      "repeatable": true
    },
    "knowledgeArea": {
      "type": "component",
      "component": "organizzazione.knowledge-area",
      "repeatable": false
    }
  }
}
