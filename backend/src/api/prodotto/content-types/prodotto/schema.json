{
  "kind": "collectionType",
  "collectionName": "prodotti_items",
  "info": {
    "singularName": "prodotto",
    "pluralName": "prodotti-items",
    "displayName": "Lista Per pagina Prodotto",
    "description": "Singolo prodotto (CarFleet, Open4US, ecc.) - stile e features configurabili da admin"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Nome": {
      "type": "string",
      "required": true
    },
    "Slug": {
      "type": "uid",
      "targetField": "Nome"
    },
    "Stile": {
      "type": "enumeration",
      "required": true,
      "default": "stile-1",
      "enum": [
        "stile-1",
        "stile-2"
      ]
    },
    "Icona": {
      "type": "string"
    },
    "IconColor": {
      "type": "enumeration",
      "default": "primary",
      "enum": [
        "primary",
        "purple"
      ]
    },
    "Sottotitolo": {
      "type": "string"
    },
    "Descrizione": {
      "type": "richtext",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "ImmaginePrincipale": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "Features": {
      "type": "component",
      "component": "prodotto.feature",
      "repeatable": true
    },
    "ImmagineSecondaria": {
      "type": "media",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "Stile"
            },
            "stile-2"
          ]
        }
      },
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "CtaTesto": {
      "type": "string"
    },
    "CtaLink": {
      "type": "string"
    },
    "CtaIcona": {
      "type": "string",
      "default": "arrow_forward"
    },
    "Ordine": {
      "type": "integer",
      "default": 0
    }
  }
}
