{
  "kind": "collectionType",
  "collectionName": "prodotti_items",
  "info": {
    "singularName": "prodotto",
    "pluralName": "prodotti-items",
    "displayName": "Prodotto",
    "description": "Singolo prodotto (CarFleet, Open4US, ecc.) - stile e features configurabili da admin"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Nome": {
      "type": "string",
      "required": true,
      "description": "Nome del prodotto (es: CarFleet, Open4US)"
    },
    "Slug": {
      "type": "uid",
      "targetField": "Nome"
    },
    "Stile": {
      "type": "enumeration",
      "enum": ["stile-1", "stile-2"],
      "default": "stile-1",
      "required": true,
      "description": "stile-1: testo SX + immagine DX (CarFleet), stile-2: immagini SX + testo DX (Open4US)"
    },
    "Icona": {
      "type": "string",
      "description": "Nome icona Material Icons per header (es: directions_car, meeting_room)"
    },
    "IconColor": {
      "type": "enumeration",
      "enum": ["primary", "purple"],
      "default": "primary",
      "description": "Colore tema: primary (verde) o purple (viola)"
    },
    "Sottotitolo": {
      "type": "string",
      "description": "Sottotitolo del prodotto (es: Gestione Flotta Aziendale con PowerApps)"
    },
    "Descrizione": {
      "type": "text",
      "description": "Paragrafo descrittivo del prodotto"
    },
    "ImmaginePrincipale": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"],
      "description": "Screenshot dashboard (stile-1) o immagine prodotto (stile-2)"
    },
    "Features": {
      "type": "component",
      "repeatable": true,
      "component": "prodotto.feature",
      "description": "Lista funzionalita: renderizzata come lista (stile-1) o griglia card (stile-2)"
    },
    "ImmagineSecondaria": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"],
      "description": "Solo per stile-2: immagine di sfondo dietro l immagine principale"
    },
    "CtaTesto": {
      "type": "string",
      "description": "Testo link CTA (es: Esplora le Funzionalita di CarFleet)"
    },
    "CtaLink": {
      "type": "string",
      "description": "URL destinazione CTA (es: /carfleet)"
    },
    "CtaIcona": {
      "type": "string",
      "default": "arrow_forward",
      "description": "Icona freccia CTA (es: arrow_forward)"
    },
    "Ordine": {
      "type": "integer",
      "default": 0,
      "description": "Ordine di visualizzazione nella pagina prodotti (crescente)"
    }
  }
}