{
  "kind": "collectionType",
  "collectionName": "servizi",
  "info": {
    "singularName": "servizio",
    "pluralName": "servizi",
    "displayName": "Lista Servizi offerti",
    "description": "Servizi IT offerti dall'azienda"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "titolo": {
      "type": "string",
      "required": true
    },
    "descrizione": {
      "type": "text",
      "required": true
    },
    "icona": {
      "type": "customField",
      "customField": "plugin::icon-picker.icon",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "titolo"
    },
    "ordine": {
      "type": "integer",
      "default": 0
    }
  }
}
