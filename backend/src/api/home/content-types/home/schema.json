{
  "kind": "singleType",
  "collectionName": "homes",
  "info": {
    "singularName": "home",
    "pluralName": "homes",
    "displayName": "Pagina Home Page",
    "description": "Contenuti della pagina principale"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "heroTag": {
      "type": "string"
    },
    "heroTitle": {
      "type": "string",
      "required": true
    },
    "heroSubtitle": {
      "type": "richtext",
      "customField": "plugin::ckeditor5.CKEditor",
      "required": true,
      "options": {
        "preset": "defaultHtml"
      }
    },
    "heroImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "introTitle": {
      "type": "string"
    },
    "introDescription": {
      "type": "richtext",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "einsteinQuote": {
      "type": "text"
    },
    "servicesTitle": {
      "type": "string"
    },
    "servicesSubtitle": {
      "type": "string"
    }
  }
}
