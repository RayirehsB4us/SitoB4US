                                <img alt="" class="inline-block h-10 w-10 rounded-full ring-2 ring-white"
                                    src="https://lh3.googleusercontent.com/aida-public/AB6AXuAmY6M6OpRVWL5sxYnurQ1iGOfgsMYJEMte2y8n5_LM2BZetUJG8KzIuUIt2Z6ofnUd7xCLkh4JWn2pc_UOmymkAOGViZL9EFn7c8I3xaHx3-l5Fa4yHE3va38UOOJhIhvTkBz-Orqz14AZdh7hd-adGIYnpg8m5cYWCOixteqByKYvQpowRbOfVIyAQxJZV7FtYtTfz95VRP5iTddpzlwGRJEWjbcvaHARb9DTSReEBpDwb7zhSaM5GUGzq1T4IanZOyTDlQyl2jpU" />
