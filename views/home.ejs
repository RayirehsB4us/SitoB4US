                        <div
                            class="w-14 h-14 bg-green-50 rounded-xl flex items-center justify-center mb-6 group-hover:bg-primary transition-colors">
                            <span
                                class="material-symbols-outlined text-primary group-hover:text-white transition-colors text-3xl">developer_mode</span>
                        </div>
                        <h3 class="text-xl font-bold mb-3">Software Development</h3>
                        <p class="text-gray-600">Sviluppo di soluzioni software personalizzate per scalare i tuoi
                            processi operativi.</p>
                    </div>
                </div>
            </div>
