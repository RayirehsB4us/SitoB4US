<!DOCTYPE html>
<html class="scroll-smooth" lang="it">

<head>
  <%- include('partials/head') %>
    <style>
      .masonry-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        grid-gap: 2rem;
      }
    </style>
</head>

<body class="bg-background-light text-slate-900 font-sans transition-colors duration-300">
  <%- include('partials/navbar') %>

    <header class="py-16 md:py-24 bg-gradient-to-b from-slate-50 to-background-light overflow-hidden relative">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="max-w-3xl">
          <h1
            class="text-5xl md:text-6xl font-display font-bold mb-6 bg-clip-text text-transparent bg-gradient-to-r from-primary to-green-400">
            B4US Tech Insights
          </h1>
          <p class="text-lg md:text-xl text-slate-600 mb-8 leading-relaxed">
            Esploriamo il futuro della tecnologia IT, della consulenza aziendale e delle soluzioni digitali per
            semplificare il tuo business.
          </p>
          <div class="flex flex-col md:flex-row gap-4">
            <div class="relative flex-grow">
              <span
                class="material-symbols-outlined absolute left-4 top-1/2 transform -translate-y-1/2 text-slate-400">search</span>
              <input
                class="w-full pl-12 pr-4 py-4 rounded-2xl bg-white border-2 border-slate-200 focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all outline-none"
                placeholder="Cerca articoli..." type="text" />
            </div>
            <select
              class="px-6 py-4 rounded-2xl bg-white border-2 border-slate-200 focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all outline-none appearance-none cursor-pointer">
              <option>Tutte le categorie</option>
              <option>Cybersecurity</option>
              <option>Cloud Strategy</option>
              <option>AI &amp; Data</option>
              <option>Innovazione</option>
            </select>
          </div>
        </div>
      </div>
      <div class="absolute top-0 right-0 w-96 h-96 bg-primary/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-80 h-80 bg-green-300/10 rounded-full blur-3xl"></div>
    </header>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="masonry-grid">
        <article
          class="group bg-card-light dark:bg-card-dark rounded-3xl overflow-hidden shadow-sm border border-slate-100 dark:border-slate-800 hover:shadow-2xl transition-all duration-500 hover:-translate-y-1">
          <div class="relative overflow-hidden aspect-[16/10]">
            <img alt="Cybersecurity"
              class="object-cover w-full h-full group-hover:scale-110 transition-transform duration-700"
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuDLQuOSurLeETD_rH8oPkGHF7mPB88uSW93rDVp37O2jJ4LIlzJPTt4MGKIRUYU8AGRkpTEPcXcIhrF06pp89v6F8g2rmeFhLVZDKt88v3J4oQMlE3ReizdGZ9SwFgl3x8hNkQRzBvlziPrEAeggWNC0OV6bujjw60M2VtM142cQQItXskf_4Jy0Af8VqrB80QIjvHdhreFoLFz3LdeJy0FIIXUkNgvfXQ6TswSz0CNNOwmpHBSFfTEMa-UZuAJS8hPuXZAZRpUQxSP" />
            <div class="absolute top-4 left-4">
              <span
                class="bg-primary/90 backdrop-blur-md text-white px-3 py-1 rounded-lg text-xs font-bold uppercase tracking-wider">Cybersecurity</span>
            </div>
          </div>
          <div class="p-8">
            <div class="flex items-center gap-4 text-xs text-slate-500 dark:text-slate-400 mb-4">
              <span class="flex items-center gap-1"><span
                  class="material-symbols-outlined text-base">calendar_today</span> 12 Maggio 2024</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-base">schedule</span> 5
                min lettura</span>
            </div>
            <h2 class="text-2xl font-display font-bold mb-4 group-hover:text-primary transition-colors">La Nuova
              Frontiera
              della Sicurezza Informatica nel 2024</h2>
            <p class="text-slate-600 dark:text-slate-400 mb-6 line-clamp-3">
              Scopri come le aziende stanno adottando l'approccio Zero Trust per contrastare le minacce sempre più
              sofisticate guidate dall'AI.
            </p>
            <a class="inline-flex items-center font-semibold text-primary group/link" href="#">
              Leggi di più
              <span
                class="material-symbols-outlined ml-1 group-hover/link:translate-x-1 transition-transform">arrow_forward</span>
            </a>
          </div>
        </article>
        <article
          class="group bg-card-light dark:bg-card-dark rounded-3xl overflow-hidden shadow-sm border border-slate-100 dark:border-slate-800 hover:shadow-2xl transition-all duration-500 hover:-translate-y-1">
          <div class="relative overflow-hidden aspect-[16/10]">
            <img alt="Artificial Intelligence"
              class="object-cover w-full h-full group-hover:scale-110 transition-transform duration-700"
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuBM7UhN8d8zb3YgLk3gqGPlsXIyv_Gj5VZzqFqRXiSU2_S8TAYCp7Foz1aVNJJf_-xBXUDympNOD4lqECklTuZXewSn1gVgGvBp_AGhQDMZi91jWXF4Bcb3lg0VijG-dR6AKqW4YzobX_Oq8foUe2b10uyMzZMk0CGnjuxVGE-9pIvhRs626RPW_3PXwHdIgCf1re85wjUDs-ErxKMxGTDZk0El5jHnnzT5eXqVaf-B6SXtT9BFgKw2_B_TitoH0yeX2oagSbkHcBk_" />
            <div class="absolute top-4 left-4">
              <span
                class="bg-primary/90 backdrop-blur-md text-white px-3 py-1 rounded-lg text-xs font-bold uppercase tracking-wider">AI
                &amp; Data</span>
            </div>
          </div>
          <div class="p-8">
            <div class="flex items-center gap-4 text-xs text-slate-500 dark:text-slate-400 mb-4">
              <span class="flex items-center gap-1"><span
                  class="material-symbols-outlined text-base">calendar_today</span> 8 Maggio 2024</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-base">schedule</span> 8
                min lettura</span>
            </div>
            <h2 class="text-2xl font-display font-bold mb-4 group-hover:text-primary transition-colors">AI Generativa:
              Da
              Trend a Strumento Operativo per le PMI</h2>
            <p class="text-slate-600 dark:text-slate-400 mb-6 line-clamp-3">
              L'intelligenza artificiale non è più solo per i colossi tecnologici. Vediamo casi studio reali di come le
              piccole e medie imprese italiane...
            </p>
            <a class="inline-flex items-center font-semibold text-primary group/link" href="#">
              Leggi di più
              <span
                class="material-symbols-outlined ml-1 group-hover/link:translate-x-1 transition-transform">arrow_forward</span>
            </a>
          </div>
        </article>
        <article
          class="group bg-card-light dark:bg-card-dark rounded-3xl overflow-hidden shadow-sm border border-slate-100 dark:border-slate-800 hover:shadow-2xl transition-all duration-500 hover:-translate-y-1">
          <div class="relative overflow-hidden aspect-[16/10]">
            <img alt="Cloud" class="object-cover w-full h-full group-hover:scale-110 transition-transform duration-700"
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuDeoqej0IYBFI5hXbHjnxrBIhgmVVDX0gk2S3Ibr6PPIHzTl3VIaT557cI_yEQsAITtIK8jh2SYccYpfRGvUqi3-ejokFnDgRwYB5mf_S9f531MXok73ecp0kgNNqO7y6UFQM4DXFFq6mEg0iEIXquDCSdJ8723qLSRZEW2uWPj4B9dQX_iNtE3wCYqOJJc2RoGlhNnGP64nmC5tQ1boB58D_5OOAFNrktgFcmEHGQjUGM1NdP5LhnbzV_lpC2Pn8gY1MJHOD1HRa5V" />
            <div class="absolute top-4 left-4">
              <span
                class="bg-primary/90 backdrop-blur-md text-white px-3 py-1 rounded-lg text-xs font-bold uppercase tracking-wider">Cloud
                Strategy</span>
            </div>
          </div>
          <div class="p-8">
            <div class="flex items-center gap-4 text-xs text-slate-500 dark:text-slate-400 mb-4">
              <span class="flex items-center gap-1"><span
                  class="material-symbols-outlined text-base">calendar_today</span> 2 Maggio 2024</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-base">schedule</span> 4
                min lettura</span>
            </div>
            <h2 class="text-2xl font-display font-bold mb-4 group-hover:text-primary transition-colors">Migrazione
              Cloud:
              Errori Comuni e Come Evitarli</h2>
            <p class="text-slate-600 dark:text-slate-400 mb-6 line-clamp-3">
              Passare al cloud è un passo fondamentale per la digitalizzazione, ma senza una strategia chiara i costi
              possono sfuggire al controllo.
            </p>
            <a class="inline-flex items-center font-semibold text-primary group/link" href="#">
              Leggi di più
              <span
                class="material-symbols-outlined ml-1 group-hover/link:translate-x-1 transition-transform">arrow_forward</span>
            </a>
          </div>
        </article>
        <article
          class="group bg-card-light dark:bg-card-dark rounded-3xl overflow-hidden shadow-sm border border-slate-100 dark:border-slate-800 hover:shadow-2xl transition-all duration-500 hover:-translate-y-1">
          <div class="relative overflow-hidden aspect-[16/10]">
            <img alt="Tech News"
              class="object-cover w-full h-full group-hover:scale-110 transition-transform duration-700"
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuAl_rSzTgzZBsfQQKAufP399bHlU4EDynaWf_LlS60BZKCekipyUpbXR4HZStejn-tgvtxObJU4DNjxsuoRHiRkkcRs7JHF06OCCFg3E5-h9LNiIp5-R46ohuH-e3zjMi9xa6IKszAz7-23GSHisQvAGTUFkAkKhhGmov4nloaVaRBRpgXBTZ53Ve-3308Nm6JAq6zhjzznzqyeNhqkXpg9mipUd3WuUE-1X_-Xeobzd4nNkAsK2QEK2cwceeHihP5afcdpbYr0QsjM" />
            <div class="absolute top-4 left-4">
              <span
                class="bg-primary/90 backdrop-blur-md text-white px-3 py-1 rounded-lg text-xs font-bold uppercase tracking-wider">Innovazione</span>
            </div>
          </div>
          <div class="p-8">
            <div class="flex items-center gap-4 text-xs text-slate-500 dark:text-slate-400 mb-4">
              <span class="flex items-center gap-1"><span
                  class="material-symbols-outlined text-base">calendar_today</span> 25 Aprile 2024</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-base">schedule</span> 6
                min lettura</span>
            </div>
            <h2 class="text-2xl font-display font-bold mb-4 group-hover:text-primary transition-colors">Sostenibilità
              Digitale: Il Green IT come Priorità</h2>
            <p class="text-slate-600 dark:text-slate-400 mb-6 line-clamp-3">
              Come ridurre l'impatto ambientale dell'infrastruttura IT aziendale migliorando al contempo le prestazioni
              e
              riducendo i costi.
            </p>
            <a class="inline-flex items-center font-semibold text-primary group/link" href="#">
              Leggi di più
              <span
                class="material-symbols-outlined ml-1 group-hover/link:translate-x-1 transition-transform">arrow_forward</span>
            </a>
          </div>
        </article>
      </div>
      <div class="flex justify-center mt-16">
        <nav class="flex items-center gap-2">
          <button
            class="w-10 h-10 flex items-center justify-center rounded-xl border border-slate-200 dark:border-slate-700 text-slate-400 hover:text-primary hover:border-primary transition-all">
            <span class="material-symbols-outlined">chevron_left</span>
          </button>
          <button
            class="w-10 h-10 flex items-center justify-center rounded-xl bg-primary text-white font-bold">1</button>
          <button
            class="w-10 h-10 flex items-center justify-center rounded-xl border border-slate-200 dark:border-slate-700 hover:text-primary hover:border-primary transition-all">2</button>
          <button
            class="w-10 h-10 flex items-center justify-center rounded-xl border border-slate-200 dark:border-slate-700 hover:text-primary hover:border-primary transition-all">3</button>
          <span class="px-2">...</span>
          <button
            class="w-10 h-10 flex items-center justify-center rounded-xl border border-slate-200 dark:border-slate-700 hover:text-primary hover:border-primary transition-all">12</button>
          <button
            class="w-10 h-10 flex items-center justify-center rounded-xl border border-slate-200 dark:border-slate-700 text-slate-400 hover:text-primary hover:border-primary transition-all">
            <span class="material-symbols-outlined">chevron_right</span>
          </button>
        </nav>
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div
        class="bg-primary rounded-3xl p-10 md:p-16 relative overflow-hidden text-white flex flex-col md:flex-row items-center justify-between gap-10">
        <div class="relative z-10 max-w-xl">
          <h2 class="text-3xl md:text-4xl font-display font-bold mb-4">Rimani aggiornato sul mondo IT</h2>
          <p class="text-green-50 text-lg opacity-90">
            Iscriviti alla nostra newsletter per ricevere approfondimenti mensili, novità tecnologiche e consigli dai
            nostri esperti direttamente nella tua inbox.
          </p>
        </div>
        <form class="relative z-10 w-full max-w-md flex flex-col sm:flex-row gap-3">
          <input
            class="flex-grow px-6 py-4 rounded-2xl bg-white/10 border-white/20 text-white placeholder:text-white/60 focus:ring-2 focus:ring-white focus:border-transparent outline-none backdrop-blur-sm"
            placeholder="La tua email" type="email" />
          <button
            class="bg-white text-primary px-8 py-4 rounded-2xl font-bold hover:bg-green-50 transition-colors shadow-xl"
            type="submit">Iscriviti</button>
        </form>
        <div class="absolute -right-20 -bottom-20 w-80 h-80 bg-white/10 rounded-full"></div>
        <div class="absolute -left-10 -top-10 w-40 h-40 bg-white/10 rounded-full"></div>
      </div>
    </section>

    <%- include('partials/footer') %>
</body>

</html>